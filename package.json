{
  "name": "acetec-website-v8",
  "type": "module",
  "version": "8.0.0",
  "private": true,
  "description": "AceTec - Embedded & Industrial Technology Solutions (Astro)",
  "engines": {
    "node": ">=22.12.0"
  },
  "scripts": {
    "dev": "node scripts/ensure-ollama.mjs && astro dev",
    "build": "astro build",
    "deploy": "node scripts/deploy.mjs",
    "preview": "astro preview",
    "astro": "astro",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "ingest": "npx tsx scripts/ingest-embeddings.ts",
    "test": "vitest run",
    "sync": "node scripts/auto-sync.mjs",
    "watch-images": "npx tsx scripts/watch-images.ts",
    "test:watch": "vitest",
    "test:a11y": "playwright test",
    "prepare": "husky"
  },
  "lint-staged": {
    "*.{ts,astro}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{css,json,md,mjs}": [
      "prettier --write"
    ]
  },
  "dependencies": {
    "@astrojs/node": "^10.0.4",
    "@qdrant/js-client-rest": "^1.17.0",
    "@supabase/supabase-js": "^2.101.1",
    "astro": "^6.1.2",
    "bcryptjs": "^3.0.3",
    "better-sqlite3": "^12.8.0",
    "nodemailer": "^8.0.5",
    "sharp": "^0.34.5",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.11.1",
    "@playwright/test": "^1.59.1",
    "@types/bcryptjs": "^2.4.6",
    "@types/better-sqlite3": "^7.6.13",
    "@typescript-eslint/eslint-plugin": "^8.58.0",
    "@typescript-eslint/parser": "^8.58.0",
    "eslint": "^10.1.0",
    "eslint-plugin-astro": "^1.6.0",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "prettier": "^3.8.1",
    "prettier-plugin-astro": "^0.14.1",
    "vitest": "^4.1.2"
  },
  "main": "index.js",
  "directories": {
    "test": "tests"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/SungwooJang123/Acetec-Homepage.git"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "bugs": {
    "url": "https://github.com/SungwooJang123/Acetec-Homepage/issues"
  },
  "homepage": "https://github.com/SungwooJang123/Acetec-Homepage#readme"
}
