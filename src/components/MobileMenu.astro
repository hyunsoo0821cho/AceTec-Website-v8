---
/**
 * MobileMenu - 풀스크린 모바일 네비게이션 오버레이
 * v7 index.html mobile-menu 섹션에서 추출
 * ARIA, 포커스 트랩, Escape 닫기 지원
 */
import LangSwitcher from './LangSwitcher.astro';

interface Props {
  currentPath?: string;
}

const { currentPath = '/' } = Astro.props;

const navLinks = [
  { href: '/', label: '홈', i18nKey: 'nav.home' },
  { href: '/solutions', label: '솔루션', i18nKey: 'nav.solutions' },
  { href: '/products-intro', label: '제품소개', i18nKey: 'nav.productsIntro' },
  { href: '/applications', label: '응용분야', i18nKey: 'nav.applications' },
  { href: '/about', label: '회사소개', i18nKey: 'nav.about' },
  { href: '/history', label: '연혁', i18nKey: 'nav.history' },
  { href: '/contact', label: '문의하기', i18nKey: 'nav.contact' },
  { href: '/login', label: '로그인', i18nKey: 'nav.login' },
];
---

<div class="mobile-menu" id="mobileMenu" role="dialog" aria-label="Mobile navigation" aria-hidden="true" inert>
  <button class="mobile-menu-close" id="mobileMenuClose" aria-label="Close menu">&times;</button>
  {
    navLinks.map(({ href, label, i18nKey }) => (
      <a class:list={['mob-link', { active: currentPath === href }]} href={href} {...(i18nKey ? { 'data-i18n': i18nKey } : {})}>
        {label}
      </a>
    ))
  }
  <a class="btn-book" href="/contact" data-i18n="nav.inquiry">문의하기</a>
  <LangSwitcher />
</div>

<style>
  .mobile-menu {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    bottom: 0;
    background: var(--color-white);
    z-index: var(--z-mobile-menu);
    flex-direction: column;
    justify-content: center;
    align-items: center;
    gap: var(--spacing-2xl);
    display: flex;
    opacity: 0;
    visibility: hidden;
    transition:
      opacity var(--transition-slow),
      visibility var(--transition-slow);
    padding: env(safe-area-inset-top) env(safe-area-inset-right) env(safe-area-inset-bottom) env(safe-area-inset-left);
  }

  .mobile-menu.open {
    opacity: 1;
    visibility: visible;
  }

  .mob-link {
    font-size: var(--font-size-4xl);
    font-weight: 400;
    color: var(--color-black);
    cursor: pointer;
    text-decoration: none;
    font-family: var(--font-family);
    letter-spacing: -0.02em;
  }

  .mob-link:hover {
    opacity: 0.6;
  }

  .mob-link.active {
    font-weight: 700;
    text-decoration: underline;
    text-underline-offset: 6px;
  }

  .mobile-menu .btn-book {
    font-size: var(--font-size-md);
    padding: 18px 36px;
    margin-top: 10px;
  }

  @media (max-width: 480px) {
    .mob-link {
      font-size: var(--font-size-2xl);
    }
  }
</style>
