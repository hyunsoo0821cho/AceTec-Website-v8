---
/**
 * LangSwitcher — 헤더 언어 전환 드롭다운
 */
const languages = [
  { code: 'ko', country: 'KR', label: '한국어' },
  { code: 'en', country: 'US', label: 'English' },
  { code: 'ja', country: 'JP', label: '日本語' },
  { code: 'ar', country: 'SA', label: 'العربية' },
  { code: 'fr', country: 'FR', label: 'Français' },
  { code: 'de', country: 'DE', label: 'Deutsch' },
  { code: 'es', country: 'ES', label: 'Español' },
];
---

<div class="lang-switcher" id="langSwitcher">
  <button class="lang-btn" id="langBtn" aria-label="Select language" aria-expanded="false">
    <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
      <circle cx="12" cy="12" r="10"></circle>
      <line x1="2" y1="12" x2="22" y2="12"></line>
      <path d="M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z"></path>
    </svg>
    <span id="currentLangLabel">KO</span>
  </button>
  <div class="lang-dropdown" id="langDropdown" role="listbox" aria-label="Languages">
    {languages.map((lang) => (
      <button class="lang-option" role="option" data-lang={lang.code} data-country={lang.country}>
        <span class="lang-country">{lang.country}</span> {lang.label}
      </button>
    ))}
  </div>
</div>

<style>
  .lang-switcher {
    position: relative;
  }

  .lang-btn {
    display: flex;
    align-items: center;
    gap: 5px;
    background: #1a1a1a !important;
    border: none;
    border-radius: 999px;
    padding: 7px 14px;
    font-family: var(--font-family);
    font-size: 13px;
    font-weight: 600;
    color: #fff !important;
    cursor: pointer;
    transition: opacity 0.2s;
    letter-spacing: 0.02em;
  }

  .lang-btn svg {
    stroke: #fff !important;
  }

  .lang-btn:hover {
    opacity: 0.8;
  }

  .lang-dropdown {
    position: absolute;
    top: calc(100% + 8px);
    right: 0;
    background: var(--color-white);
    border: 1px solid var(--color-gray-200);
    border-radius: var(--radius-md);
    box-shadow: var(--shadow-lg);
    min-width: 180px;
    max-height: 320px;
    overflow-y: auto;
    opacity: 0;
    visibility: hidden;
    transform: translateY(-8px);
    transition: all var(--transition-base);
    z-index: 200;
  }

  .lang-dropdown.open {
    opacity: 1;
    visibility: visible;
    transform: translateY(0);
  }

  .lang-option {
    display: block;
    width: 100%;
    padding: 10px 16px;
    background: none;
    border: none;
    text-align: left;
    font-family: var(--font-family);
    font-size: var(--font-size-base);
    color: var(--color-black);
    cursor: pointer;
    transition: background var(--transition-fast);
  }

  .lang-option:hover {
    background: var(--color-gray-100);
  }

  .lang-option.active {
    font-weight: 600;
    background: var(--color-gray-100);
  }

  .lang-country {
    display: inline-block;
    min-width: 24px;
    font-weight: 600;
    font-size: var(--font-size-sm);
    color: var(--color-gray-700);
  }

  @media (max-width: 768px) {
    .lang-btn {
      padding: 6px 10px;
      font-size: 12px;
    }
  }
</style>

<script>
  import { getCurrentLang, setLang, applyTranslations, LANGUAGES } from '../i18n/index';
  import type { LangCode } from '../i18n/index';

  const btn = document.getElementById('langBtn')!;
  const dropdown = document.getElementById('langDropdown')!;
  const label = document.getElementById('currentLangLabel')!;

  // Initialize with current language
  const current = getCurrentLang();
  label.textContent = current.toUpperCase();

  // Mark active
  dropdown.querySelectorAll('.lang-option').forEach(opt => {
    if (opt.getAttribute('data-lang') === current) opt.classList.add('active');
  });

  // Toggle dropdown
  btn.addEventListener('click', (e) => {
    e.stopPropagation();
    const isOpen = dropdown.classList.toggle('open');
    btn.setAttribute('aria-expanded', isOpen ? 'true' : 'false');
  });

  // Select language
  dropdown.addEventListener('click', async (e) => {
    const opt = (e.target as HTMLElement).closest('.lang-option');
    if (!opt) return;
    const code = opt.getAttribute('data-lang') as LangCode;

    // Update active state
    dropdown.querySelectorAll('.lang-option').forEach(o => o.classList.remove('active'));
    opt.classList.add('active');

    // Apply language
    setLang(code);
    label.textContent = code.toUpperCase();
    dropdown.classList.remove('open');
    btn.setAttribute('aria-expanded', 'false');
  });

  // Close on outside click
  document.addEventListener('click', () => {
    dropdown.classList.remove('open');
    btn.setAttribute('aria-expanded', 'false');
  });

  // Apply translations on load
  applyTranslations();
</script>
