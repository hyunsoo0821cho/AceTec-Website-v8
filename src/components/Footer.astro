---
/**
 * Footer - JSON 기반 + 관리자 인라인 편집
 */
import { verifySession, getSessionIdFromCookie, getUserInfo } from '../lib/auth';
import fs from 'fs';
import path from 'path';
let isAdmin = false;
let d: any = null;

try {
  const cookie = Astro.request.headers.get('cookie');
  const sessionId = verifySession(getSessionIdFromCookie(cookie));
  if (sessionId) {
    const userInfo = getUserInfo(sessionId);
    isAdmin = userInfo?.role === 'admin';
  }
  const root = process.cwd();
  d = JSON.parse(fs.readFileSync(path.join(root, 'src', 'content', 'pages', 'footer.json'), 'utf-8'));
} catch {
  // Static prerender fallback
  d = null;
}

function e(p: string) {
  return isAdmin ? { 'data-edit': p, 'data-edit-page': 'footer' } : {};
}

// href → i18n key for footer solution links
const solI18n: Record<string, string> = {
  '/products/military': 'products.military',
  '/products/railway': 'products.railway',
  '/products/industrial': 'products.industrial',
  '/products/telecom': 'products.telecom',
  '/products/sensor': 'products.sensor',
  '/products/hpc': 'products.hpc',
  '/products/ipc': 'products.ipc',
  '/products/radar': 'products.radar',
  '/products/interconnect': 'products.interconnect',
};
// href → i18n key for footer company links
const compI18n: Record<string, string> = {
  '/solutions': 'nav.solutions',
  '/applications': 'nav.applications',
  '/about': 'nav.about',
  '/history': 'nav.history',
  '/contact': 'nav.contact',
};
---

<footer class="site-footer">
  <div class="footer-grid">
    <div class="footer-col">
      <h4>AceTec</h4>
      {
        d ? (
          <p {...e('companyDescription')} data-i18n="home.companyDesc">{d.companyDescription}</p>
        ) : (
          <p data-i18n="home.companyDesc">
            Trusted for over 30 years in embedded computing, industrial PCs, and safety-critical systems — serving
            defense, aerospace, railway, and industrial markets.
          </p>
        )
      }
    </div>
    <div class="footer-col">
      <h4 data-i18n="nav.solutions">솔루션</h4>
      {
        d?.solutionLinks ? (
          <>
            {d.solutionLinks.map((link: any, i: number) => (
              <div class="footer-link-row">
                <a href={link.href} {...e(`solutionLinks[${i}].label`)} {...(solI18n[link.href] ? {'data-i18n': solI18n[link.href]} : {})}>{link.label}</a>
                {isAdmin && <button class="footer-del-btn" data-admin-delete={`solutionLinks[${i}]`} data-edit-page="footer">&times;</button>}
              </div>
            ))}
            {isAdmin && (
              <button
                class="admin-add-btn footer-add-btn"
                data-admin-add="solutionLinks"
                data-edit-page="footer"
                data-admin-template='{"label":"New Link","href":"/solutions"}'
              >+ Add</button>
            )}
          </>
        ) : (
          <>
            <a href="/products/military">군수항공분야</a>
            <a href="/products/railway">철도분야</a>
            <a href="/products/industrial">자동화분야</a>
            <a href="/products/telecom">정보통신분야</a>
            <a href="/products/sensor">모델링 &amp; 시뮬레이션 분야</a>
            <a href="/products/hpc">슈퍼컴퓨팅시스템분야</a>
            <a href="/products/ipc">산업용컴퓨터분야</a>
            <a href="/products/radar">레이더</a>
            <a href="/products/interconnect">초고속 데이터 인터커넥트</a>
          </>
        )
      }
    </div>
    <div class="footer-col">
      <h4 data-i18n="footer.company">회사</h4>
      {
        d?.companyLinks ? (
          <>
            {d.companyLinks.map((link: any, i: number) => (
              <div class="footer-link-row">
                <a href={link.href} {...e(`companyLinks[${i}].label`)} {...(compI18n[link.href] ? {'data-i18n': compI18n[link.href]} : {})}>{link.label}</a>
                {isAdmin && <button class="footer-del-btn" data-admin-delete={`companyLinks[${i}]`} data-edit-page="footer">&times;</button>}
              </div>
            ))}
            {isAdmin && (
              <button
                class="admin-add-btn footer-add-btn"
                data-admin-add="companyLinks"
                data-edit-page="footer"
                data-admin-template='{"label":"New Link","href":"/"}'
              >+ Add</button>
            )}
          </>
        ) : (
          <>
            <a href="/solutions">솔루션</a>
            <a href="/applications">적용 분야</a>
            <a href="/about">회사 소개</a>
            <a href="/history">연혁</a>
            <a href="/contact">문의</a>
          </>
        )
      }
    </div>
    <div class="footer-col">
      <h4 data-i18n="footer.partners">파트너</h4>
      {
        d?.partners ? (
          <>
            {d.partners.map((p: any, i: number) => (
              <div class="footer-link-row">
                <a href={p.url} target="_blank" rel="noopener" {...e(`partners[${i}].name`)}>{p.name}</a>
                {isAdmin && <button class="footer-del-btn" data-admin-delete={`partners[${i}]`} data-edit-page="footer">&times;</button>}
              </div>
            ))}
            {isAdmin && (
              <button
                class="admin-add-btn footer-add-btn"
                data-admin-add="partners"
                data-edit-page="footer"
                data-admin-template='{"name":"New Partner","url":"https://example.com"}'
              >+ Add</button>
            )}
          </>
        ) : (
          <>
            <a href="https://www.abaco.com" target="_blank" rel="noopener">Abaco Systems</a>
            <a href="https://www.artesyn.com" target="_blank" rel="noopener">SMART Embedded Computing</a>
            <a href="https://www.onestopsystems.com" target="_blank" rel="noopener">OneStopSystems</a>
            <a href="https://www.pentek.com" target="_blank" rel="noopener">Pentek</a>
            <a href="https://www.windriver.com" target="_blank" rel="noopener">Wind River</a>
            <a href="https://www.oktal-se.fr" target="_blank" rel="noopener">OKTAL-SE</a>
            <a href="https://www.rti.com" target="_blank" rel="noopener">RTI</a>
            <a href="https://www.hima.com" target="_blank" rel="noopener">HIMA</a>
            <a href="https://www.cambridgepixel.com" target="_blank" rel="noopener">Cambridge Pixel</a>
          </>
        )
      }
    </div>
    <div class="footer-col">
      <h4 data-i18n="footer.contact">CONTACT</h4>
      {
        d?.contact ? (
          <>
            <p>
              <strong {...e('contact.seoulLabel')} data-i18n="footer.seoulHQ">{d.contact.seoulLabel}</strong><br />
              <span {...e('contact.seoulEmail')}>{d.contact.seoulEmail}</span><br />
              <span {...e('contact.seoulPhone')}>{d.contact.seoulPhone}</span><br />
              <span {...e('contact.seoulFax')}>{d.contact.seoulFax}</span>
            </p>
            <p>
              <strong {...e('contact.daejeonLabel')} data-i18n="footer.daejeonBranch">{d.contact.daejeonLabel}</strong><br />
              <span {...e('contact.daejeonAddress')} data-i18n="footer.daejeonAddr">{d.contact.daejeonAddress}</span><br />
              <span {...e('contact.daejeonPhone')}>{d.contact.daejeonPhone}</span><br />
              <span {...e('contact.daejeonFax')}>{d.contact.daejeonFax}</span>
            </p>
          </>
        ) : (
          <>
            <p>
              <strong>Seoul HQ</strong><br />
              acetec@acetec-korea.co.kr<br />
              +82-2-420-2343<br />
              FAX: +82-2-420-2757
            </p>
            <p>
              <strong>Daejeon Branch</strong><br />
              Rm. 205, Migeon Techno World, 199, Techno 2-ro, Yuseong-gu, Daejeon<br />
              +82-42-471-2343<br />
              FAX: +82-42-933-2642
            </p>
          </>
        )
      }
    </div>
  </div>
  <div class="footer-bottom">
    {
      d?.copyright ? (
        <>
          <span {...e('copyright.company')} data-i18n="footer.corpName">{d.copyright.company}</span> &middot; <span data-i18n="footer.ceoLabel">CEO</span>: <span {...e('copyright.ceo')} data-i18n="footer.ceoName">{d.copyright.ceo}</span> &middot; <span data-i18n="footer.bizLabel">Biz No</span>: <span {...e('copyright.bizNo')}>{d.copyright.bizNo}</span>
          <br />
          &copy; {new Date().getFullYear()} {d.copyright.company} All rights reserved.
        </>
      ) : (
        <>
          AceTec Co., Ltd. &middot; CEO: Jang Jeong Hoon &middot; Biz No: 215-81-68464
          <br />
          &copy; {new Date().getFullYear()} AceTec Co., Ltd. All rights reserved.
        </>
      )
    }
  </div>
</footer>
<style>
  .site-footer {
    background: var(--color-black);
    color: var(--color-white);
    padding: var(--spacing-5xl) var(--container-padding) var(--spacing-2xl);
    padding-bottom: max(var(--spacing-2xl), env(safe-area-inset-bottom));
  }

  .footer-grid {
    display: grid;
    grid-template-columns: 2fr 1fr 1fr 1fr;
    gap: var(--spacing-3xl);
    margin: 0 auto;
  }

  .footer-col h4 {
    font-size: var(--font-size-md);
    font-weight: 500;
    margin-bottom: var(--spacing-md);
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  .footer-col p {
    font-size: var(--font-size-base);
    line-height: 1.6;
    color: var(--color-footer-link);
  }

  .footer-col a {
    display: block;
    font-size: var(--font-size-base);
    color: var(--color-footer-link);
    padding: 6px 0;
    transition: color var(--transition-base);
  }

  .footer-col a:hover {
    color: var(--color-white);
  }

  .footer-add-btn {
    margin-top: 8px;
    font-size: 12px;
    padding: 4px 10px;
    background: transparent;
    border: 1px dashed #475569;
    color: #94a3b8;
    border-radius: 4px;
    cursor: pointer;
  }
  .footer-add-btn:hover {
    border-color: #3b82f6;
    color: #3b82f6;
  }

  .footer-link-row {
    display: flex;
    align-items: center;
    gap: 6px;
  }
  .footer-link-row a {
    flex: 1;
    min-width: 0;
  }
  .footer-del-btn {
    width: 18px;
    height: 18px;
    border-radius: 50%;
    border: none;
    background: #ef4444;
    color: #fff;
    font-size: 12px;
    line-height: 1;
    cursor: pointer;
    flex-shrink: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    opacity: 0;
    transition: opacity 0.15s;
  }
  .footer-link-row:hover .footer-del-btn { opacity: 1; }
  .footer-del-btn:hover { background: #dc2626; }

  .footer-bottom {
    margin: var(--spacing-3xl) auto 0;
    padding-top: var(--spacing-lg);
    border-top: 1px solid var(--color-gray-900);
    font-size: var(--font-size-sm);
    color: var(--color-gray-700);
    text-align: center;
  }

  @media (max-width: 1024px) {
    .footer-grid {
      grid-template-columns: 1fr 1fr;
    }
  }

  @media (max-width: 768px) {
    .footer-grid {
      grid-template-columns: 1fr;
    }
    .footer-col a {
      padding: 10px 0;
    }
    .site-footer {
      padding: var(--spacing-3xl) var(--spacing-lg) var(--spacing-lg);
    }
  }
</style>
