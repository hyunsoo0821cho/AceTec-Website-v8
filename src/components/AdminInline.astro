---
interface Props {
  page: string;
  isAdmin: boolean;
}
const { page, isAdmin } = Astro.props;
---

{isAdmin && (
  <div class="admin-bar" id="adminBar">
    <div class="admin-bar-inner">
      <div class="admin-bar-label-wrap">
        <span class="admin-bar-label" data-i18n="admin.editing">Editing</span>:&nbsp;<strong>{page}</strong>
      </div>
      <div class="admin-bar-actions">
        <span class="admin-bar-status" id="adminStatus"></span>
        <button class="admin-btn admin-btn-save" id="adminSave" data-i18n="admin.save">Save</button>
        <a href="/admin/dashboard" class="admin-btn admin-btn-dash" data-i18n="admin.dashboard">Dashboard</a>
        <a href="https://survey.acetecsurvey.com/survey" target="_blank" rel="noopener" class="admin-btn admin-btn-survey" data-i18n="admin.survey">Sales Channel</a>
        <form method="POST" action="/api/auth/logout" style="display:inline;">
          <button type="submit" class="admin-btn admin-btn-logout" data-i18n="admin.logout">Logout</button>
        </form>
      </div>
    </div>
  </div>
  <input type="file" id="adminImgInput" accept="image/jpeg,image/png,image/webp,image/gif" style="display:none;" />

  <style>
    .admin-bar { position:fixed; top:0; left:0; right:0; z-index:99999; background:#1e293b; color:#fff; font-family:-apple-system,BlinkMacSystemFont,'Segoe UI',sans-serif; font-size:13px; box-shadow:0 2px 8px rgba(0,0,0,.2); }
    .admin-bar-inner { max-width:1400px; margin:0 auto; padding:8px 24px; display:flex; justify-content:space-between; align-items:center; }
    .admin-bar-label-wrap { color:#94a3b8; display:inline-flex; align-items:center; }
    .admin-bar-label-wrap strong { color:#fff; font-weight:600; }
    .admin-bar-label { color:#94a3b8; }
    .admin-bar-actions { display:flex; gap:8px; align-items:center; }
    .admin-bar-status { font-size:12px; margin-right:4px; }
    .admin-btn { padding:5px 12px; border:none; border-radius:4px; font-size:12px; font-weight:600; cursor:pointer; text-decoration:none; display:inline-block; color:#fff; }
    .admin-btn-save { background:#2563eb; } .admin-btn-save:hover { background:#1d4ed8; }
    .admin-btn-dash { background:#334155; color:#cbd5e1; } .admin-btn-dash:hover { background:#475569; }
    .admin-btn-survey { background:#059669; color:#fff; } .admin-btn-survey:hover { background:#047857; }
    .admin-btn-logout { background:transparent; color:#94a3b8; border:1px solid #475569; } .admin-btn-logout:hover { color:#fff; border-color:#64748b; }

    /* Drag-to-reorder visual feedback (admin only) */
    [data-admin-sort] > [data-sort-id] { cursor: grab; }
    [data-admin-sort] > [data-sort-id]:active { cursor: grabbing; }
    [data-admin-sort] > [data-sort-id].sort-dragging { opacity: 0.35; }
    [data-admin-sort] > [data-sort-id].sort-over-before { box-shadow: -4px 0 0 0 #2563eb; }
    [data-admin-sort] > [data-sort-id].sort-over-after  { box-shadow:  4px 0 0 0 #2563eb; }
    [data-admin-sort] > [data-sort-id].sort-over-top    { box-shadow: 0 -4px 0 0 #2563eb; }
    [data-admin-sort] > [data-sort-id].sort-over-bottom { box-shadow: 0  4px 0 0 #2563eb; }
  </style>

  <!-- 글로벌: 빈 p-features ul 의 플레이스홀더 + 편집 편의 규칙.
       Astro scoped CSS가 ProductGrid / catalog 등 외부 컴포넌트의 .p-features 에 매치되지 않아
       반드시 is:global 로 선언해야 관리자 설명 영역이 정상 동작. -->
  <style is:global>
    .p-features--empty {
      min-height: 44px;
      padding: 10px 12px;
      border-radius: 6px;
      cursor: text;
      list-style: none;
    }
    .p-features--empty::before {
      content: "클릭하여 설명 추가 (여러 줄은 Enter)";
      color: #94a3b8;
      font-style: italic;
      font-size: 14px;
      line-height: 1.4;
      pointer-events: none;
    }
    /* 편집 상태로 진입하면 ul 자체가 충분한 높이를 확보해 클릭/붙여넣기 타겟이 되도록 */
    .p-features[contenteditable="true"] {
      min-height: 44px;
      padding: 10px 12px;
      border-radius: 6px;
      outline-offset: 3px;
    }
    .p-features[contenteditable="true"]:empty::before {
      content: "설명을 입력하세요...";
      color: #cbd5e1;
      font-style: italic;
      pointer-events: none;
    }
  </style>

  <script define:vars={{ page }}>
    document.addEventListener('DOMContentLoaded', () => {
      const bar = document.getElementById('adminBar');
      if (!bar) return;
      const barH = bar.offsetHeight;
      document.body.style.paddingTop = barH + 'px';
      const header = document.querySelector('.header, header, #mainHeader');
      if (header) header.style.top = barH + 'px';
      const mm = document.getElementById('mobileMenu');
      if (mm) mm.style.top = barH + 'px';

      // ===== TEXT EDITING =====
      const editables = document.querySelectorAll('[data-edit]');
      editables.forEach(el => {
        el.style.cursor = 'text';
        el.style.transition = 'outline .15s, background .15s';
        el.addEventListener('mouseenter', () => {
          if (!el.isContentEditable) { el.style.outline = '2px dashed #3b82f6'; el.style.outlineOffset = '3px'; }
        });
        el.addEventListener('mouseleave', () => {
          if (!el.isContentEditable) el.style.outline = 'none';
        });
        el.addEventListener('click', (ev) => {
          if (el.isContentEditable) return;
          ev.preventDefault(); ev.stopPropagation();
          // i18n 번역 중이었다면 편집은 원문(한국어)으로 — 번역된 텍스트가 저장되는 사고 방지
          const original = el.getAttribute('data-i18n-original');
          if (original && el.textContent !== original) { el.textContent = original; }
          // 빈 features placeholder 진입 — 내용은 비워두고 클래스만 제거.
          // CSS .p-features--empty::before 가 플레이스홀더 문구 표시,
          // 클래스 제거 시점에 placeholder 즉시 사라지고 ul 영역이 편집 가능.
          if (el.classList.contains('p-features--empty')) {
            el.innerHTML = '';
            el.classList.remove('p-features--empty');
          }
          el.contentEditable = 'true';
          el.style.outline = '2px solid #2563eb'; el.style.outlineOffset = '3px';
          el.style.background = 'rgba(59,130,246,.06)'; el.style.borderRadius = '4px';
          el.focus();
        });
        el.addEventListener('blur', () => {
          el.contentEditable = 'false'; el.style.outline = 'none'; el.style.background = '';
          // p-features(ul) 설명 영역이 비어있으면 플레이스홀더 자동 복원 — CSS가 플레이스홀더를 그려주도록 클래스만 재부여
          if (el.classList.contains('p-features')) {
            const text = (el.textContent || '').replace(/\s+/g, '');
            if (text === '') {
              el.innerHTML = '';
              el.classList.add('p-features--empty');
            }
          }
          // 편집 종료 후 현재 언어로 재번역 (다시 보기용)
          if (typeof window.__retranslateElement === 'function') window.__retranslateElement(el);
        });
        el.addEventListener('keydown', (ev) => { if (ev.key === 'Escape') { el.contentEditable = 'false'; el.style.outline = 'none'; el.style.background = ''; el.blur(); } });
      });

      // ===== IMAGE EDITING =====
      const imgInput = document.getElementById('adminImgInput');
      let activeImg = null;
      let activePreset = 'product';

      document.querySelectorAll('[data-img]').forEach(imgEl => {
        // Create badge that floats over the image using the image's own position
        const badge = document.createElement('div');
        badge.textContent = '📷 Replace';
        badge.style.cssText = 'position:absolute;bottom:8px;right:8px;background:rgba(37,99,235,.9);color:#fff;font-size:11px;padding:3px 7px;border-radius:4px;z-index:10;opacity:0;transition:opacity .2s;cursor:pointer;pointer-events:none;';

        // Wrap image in a relative container so badge stays on the image
        let wrapper = document.createElement('div');
        wrapper.style.cssText = 'position:relative;display:inline-block;';

        const imgPos = getComputedStyle(imgEl).position;
        const parentEl = imgEl.parentElement;
        const parentPos = parentEl ? getComputedStyle(parentEl).position : 'static';
        if (imgPos === 'absolute' || parentPos === 'absolute' || parentPos === 'fixed') {
          // Image or parent is absolute/fixed (e.g. .hero-bg, .p-img) — don't wrap
          if (parentEl) {
            if (parentPos === 'static') parentEl.style.position = 'relative';
            parentEl.appendChild(badge);
            wrapper = parentEl;
          }
        } else {
          // Normal flow image — wrap it
          imgEl.parentElement?.insertBefore(wrapper, imgEl);
          wrapper.appendChild(imgEl);
          wrapper.appendChild(badge);
        }

        const container = wrapper;

        // Show badge on hover over the container
        container.addEventListener('mouseenter', () => { badge.style.opacity = '1'; badge.style.pointerEvents = 'auto'; });
        container.addEventListener('mouseleave', () => { badge.style.opacity = '0'; badge.style.pointerEvents = 'none'; });

        badge.addEventListener('click', (ev) => {
          ev.preventDefault(); ev.stopPropagation();
          activeImg = imgEl;
          activePreset = imgEl.getAttribute('data-preset') || 'product';
          imgInput.click();
        });
      });

      imgInput?.addEventListener('change', async () => {
        const file = imgInput.files?.[0];
        if (!file || !activeImg) return;
        const status = document.getElementById('adminStatus');
        if (status) { status.textContent = 'Uploading...'; status.style.color = '#fbbf24'; }
        const form = new FormData();
        form.append('image', file);
        form.append('preset', activePreset);
        try {
          const res = await fetch('/api/images/upload', { method: 'POST', body: form });
          const data = await res.json();
          if (!res.ok) { if (status) { status.textContent = data.error; status.style.color = '#f87171'; } return; }
          if (activeImg.tagName === 'IMG') {
            activeImg.src = data.image_path;
          } else {
            // Replace placeholder div with real img
            const newImg = document.createElement('img');
            newImg.src = data.image_path;
            newImg.alt = '';
            newImg.loading = 'lazy';
            newImg.style.cssText = 'position:absolute;top:0;left:0;width:100%;height:100%;object-fit:cover;';
            newImg.setAttribute('data-img', activeImg.getAttribute('data-img') || '');
            newImg.setAttribute('data-preset', activeImg.getAttribute('data-preset') || 'product');
            activeImg.replaceWith(newImg);
            activeImg = newImg;
          }
          activeImg.setAttribute('data-new-src', data.image_path);
          if (status) { status.textContent = 'Replaced — Save to keep'; status.style.color = '#4ade80'; }
        } catch {
          if (status) { status.textContent = 'Upload failed'; status.style.color = '#f87171'; }
        }
        imgInput.value = '';
      });

      // ===== DRAG-TO-REORDER =====
      // 컨테이너: [data-admin-sort="<arrayPath>"]
      // 항목: [data-sort-id="<originalIndex>"]
      // 드롭 후 컨테이너에 data-sort-changed="1" 플래그가 붙어 Save 시 배열 순서 PUT.
      document.querySelectorAll('[data-admin-sort]').forEach(container => {
        let draggedCard = null;
        const items = container.querySelectorAll(':scope > [data-sort-id]');
        const isHorizontalLayout = () => {
          if (items.length < 2) return true;
          const a = items[0].getBoundingClientRect();
          const b = items[1].getBoundingClientRect();
          return Math.abs(a.top - b.top) < Math.min(a.height, b.height) / 2;
        };
        const clearOver = () => {
          container.querySelectorAll('.sort-over-before,.sort-over-after,.sort-over-top,.sort-over-bottom')
            .forEach(e => e.classList.remove('sort-over-before','sort-over-after','sort-over-top','sort-over-bottom'));
        };
        items.forEach(card => {
          card.addEventListener('dragstart', (ev) => {
            // contenteditable 안에서 시작된 드래그는 무시 (텍스트 드래그로 취급)
            if (ev.target && ev.target.isContentEditable) return;
            draggedCard = card;
            setTimeout(() => card.classList.add('sort-dragging'), 0);
            ev.dataTransfer.effectAllowed = 'move';
            ev.dataTransfer.setData('text/plain', card.getAttribute('data-sort-id') || '');
          });
          card.addEventListener('dragend', () => {
            card.classList.remove('sort-dragging');
            clearOver();
            draggedCard = null;
          });
          card.addEventListener('dragover', (ev) => {
            if (!draggedCard || draggedCard === card) return;
            ev.preventDefault();
            ev.dataTransfer.dropEffect = 'move';
            clearOver();
            const rect = card.getBoundingClientRect();
            if (isHorizontalLayout()) {
              const after = ev.clientX > rect.left + rect.width / 2;
              card.classList.add(after ? 'sort-over-after' : 'sort-over-before');
            } else {
              const after = ev.clientY > rect.top + rect.height / 2;
              card.classList.add(after ? 'sort-over-bottom' : 'sort-over-top');
            }
          });
          card.addEventListener('dragleave', () => {
            card.classList.remove('sort-over-before','sort-over-after','sort-over-top','sort-over-bottom');
          });
          card.addEventListener('drop', (ev) => {
            if (!draggedCard || draggedCard === card) return;
            ev.preventDefault();
            clearOver();
            const rect = card.getBoundingClientRect();
            const after = isHorizontalLayout()
              ? (ev.clientX > rect.left + rect.width / 2)
              : (ev.clientY > rect.top + rect.height / 2);
            if (after) card.insertAdjacentElement('afterend', draggedCard);
            else card.insertAdjacentElement('beforebegin', draggedCard);
            container.setAttribute('data-sort-changed', '1');
            const status = document.getElementById('adminStatus');
            if (status) { status.textContent = 'Order changed — Save to keep'; status.style.color = '#4ade80'; }
          });
        });
      });

      // ===== SAVE =====
      document.getElementById('adminSave')?.addEventListener('click', async () => {
        const status = document.getElementById('adminStatus');
        if (status) { status.textContent = 'Saving...'; status.style.color = '#fbbf24'; }
        try {
          // Group edits by target page
          const editsByPage = {};
          const ensure = (tp) => {
            if (!editsByPage[tp]) editsByPage[tp] = { texts: [], imgs: [], sorts: [] };
            return editsByPage[tp];
          };
          editables.forEach(el => {
            const p = el.getAttribute('data-edit');
            const targetPage = el.getAttribute('data-edit-page') || page;
            if (!p) return;
            ensure(targetPage).texts.push({ path: p, value: el.innerText.trim() });
          });
          // 이미지 변경 수집 — data-new-src 는 PUT 성공 후에만 제거 (실패 재시도 대응)
          const pendingImgs = [];
          document.querySelectorAll('[data-img][data-new-src]').forEach(im => {
            const p = im.getAttribute('data-img');
            const s = im.getAttribute('data-new-src');
            const targetPage = im.getAttribute('data-edit-page') || page;
            if (!p || !s) return;
            ensure(targetPage).imgs.push({ path: p, value: s });
            pendingImgs.push(im);
          });
          // 순서 변경 수집: [data-admin-sort][data-sort-changed]
          let hasSortChange = false;
          document.querySelectorAll('[data-admin-sort][data-sort-changed]').forEach(container => {
            const arrayPath = container.getAttribute('data-admin-sort');
            if (!arrayPath) return;
            const targetPage = container.getAttribute('data-edit-page') || page;
            const order = Array.from(container.querySelectorAll(':scope > [data-sort-id]'))
              .map(el => parseInt(el.getAttribute('data-sort-id') || '0'));
            if (order.length === 0) return;
            ensure(targetPage).sorts.push({ arrayPath, order });
            hasSortChange = true;
          });
          // Ensure main page is included even if no edits
          ensure(page);

          // i18n 동기화: 편집된 요소의 data-i18n 키도 수집
          const i18nUpdates = {};
          editables.forEach(el => {
            const i18nKey = el.getAttribute('data-i18n');
            if (i18nKey && el.getAttribute('data-edit')) {
              i18nUpdates[i18nKey] = el.innerText.trim();
            }
          });

          let allOk = true;
          let pageSaveOk = true;
          for (const [targetPage, edits] of Object.entries(editsByPage)) {
            const res = await fetch('/api/pages/' + targetPage);
            if (!res.ok) { allOk = false; pageSaveOk = false; continue; }
            const data = await res.json();
            edits.texts.forEach(e => {
              // featuresHtml → features 배열 변환
              if (e.path.endsWith('.featuresHtml')) {
                const arrPath = e.path.replace('.featuresHtml', '.features');
                const lines = e.value.split('\n').map(l => l.trim()).filter(Boolean);
                setByPath(data, arrPath, lines);
              } else {
                setByPath(data, e.path, e.value);
              }
            });
            edits.imgs.forEach(e => setByPath(data, e.path, e.value));
            // sort 순서는 text/img 적용 후 마지막에 배열 재배치 (원래 인덱스 기준 수정이 먼저 반영되어야 함)
            (edits.sorts || []).forEach(s => {
              const arr = getByPath(data, s.arrayPath);
              if (!Array.isArray(arr)) return;
              const reordered = s.order.map(oldIdx => arr[oldIdx]).filter(v => v !== undefined);
              if (reordered.length === arr.length) setByPath(data, s.arrayPath, reordered);
            });
            const saveRes = await fetch('/api/pages/' + targetPage, {
              method: 'PUT',
              headers: { 'Content-Type': 'application/json' },
              body: JSON.stringify(data),
            });
            if (!saveRes.ok) { allOk = false; pageSaveOk = false; }
          }

          // PUT 성공한 경우에만 data-new-src 제거 — 실패 시 재시도 가능
          if (pageSaveOk) {
            pendingImgs.forEach(im => im.removeAttribute('data-new-src'));
          }

          // ko + 6개 언어 자동 번역 저장 (제품명/기술파트너 제외)
          if (Object.keys(i18nUpdates).length > 0) {
            if (status) { status.textContent = 'Translating...'; status.style.color = '#fbbf24'; }
            const i18nRes = await fetch('/api/i18n/translate-save', {
              method: 'POST',
              headers: { 'Content-Type': 'application/json' },
              body: JSON.stringify({ updates: i18nUpdates }),
            });
            if (!i18nRes.ok) allOk = false;
          }

          if (status) {
            if (allOk) {
              status.textContent = 'Saved!'; status.style.color = '#4ade80';
              // 순서 변경이 포함된 저장은 DOM의 data-edit 인덱스가 어긋나므로 새 HTML로 새로고침
              if (hasSortChange) { setTimeout(() => window.location.reload(), 400); }
              else { setTimeout(() => { status.textContent = ''; }, 2000); }
            }
            else { status.textContent = 'Partial save'; status.style.color = '#fbbf24'; }
          }
        } catch (err) {
          if (status) { status.textContent = 'Save error'; status.style.color = '#f87171'; }
        }
      });

      // ===== 현재 편집 내용을 서버 데이터에 반영하는 헬퍼 =====
      async function fetchWithEdits() {
        const res = await fetch('/api/pages/' + page);
        if (!res.ok) return null;
        const data = await res.json();
        // 현재 인라인 편집 내용 반영
        editables.forEach(el => {
          const p = el.getAttribute('data-edit');
          const targetPage = el.getAttribute('data-edit-page') || page;
          if (!p || targetPage !== page) return;
          if (p.endsWith('.featuresHtml')) {
            const arrPath = p.replace('.featuresHtml', '.features');
            const lines = el.innerText.trim().split('\n').map(l => l.trim()).filter(Boolean);
            setByPath(data, arrPath, lines);
          } else {
            setByPath(data, p, el.innerText.trim());
          }
        });
        // 이미지 변경도 반영
        document.querySelectorAll('[data-img][data-new-src]').forEach(im => {
          const p = im.getAttribute('data-img');
          const s = im.getAttribute('data-new-src');
          const targetPage = im.getAttribute('data-edit-page') || page;
          if (!p || !s || targetPage !== page) return;
          setByPath(data, p, s);
        });
        return data;
      }

      // ===== ADD / DELETE =====
      // data-edit-page 지원: 대상 페이지별 데이터 fetch 헬퍼
      async function fetchPageData(targetPage) {
        if (targetPage === page) return await fetchWithEdits();
        const res = await fetch('/api/pages/' + targetPage);
        if (!res.ok) return null;
        return await res.json();
      }

      document.querySelectorAll('[data-admin-add]').forEach(btn => {
        btn.addEventListener('click', async (ev) => {
          ev.preventDefault();
          const arrayPath = btn.getAttribute('data-admin-add');
          const template = btn.getAttribute('data-admin-template');
          if (!arrayPath) return;
          const targetPage = btn.getAttribute('data-edit-page') || page;

          const status = document.getElementById('adminStatus');
          if (status) { status.textContent = 'Adding...'; status.style.color = '#fbbf24'; }

          const data = await fetchPageData(targetPage);
          if (!data) return;

          const arr = getByPath(data, arrayPath);
          if (!Array.isArray(arr)) return;

          // Parse template or use sensible default
          const newItem = template ? JSON.parse(template) : { title: 'New Item', description: '' };

          // If new item has empty image, try to pick a random one from existing items
          if (newItem.image === '' && arr.length > 0) {
            const existingImages = arr.map(item => item.image).filter(Boolean);
            if (existingImages.length > 0) {
              newItem.image = existingImages[Math.floor(Math.random() * existingImages.length)];
            }
          }

          const prepend = btn.getAttribute('data-admin-prepend') === 'true';
          if (prepend) { arr.unshift(newItem); } else { arr.push(newItem); }

          const saveRes = await fetch('/api/pages/' + targetPage, {
            method: 'PUT',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify(data),
          });

          if (saveRes.ok) {
            window.location.reload();
          } else if (status) {
            status.textContent = 'Add failed'; status.style.color = '#f87171';
          }
        });
      });

      document.querySelectorAll('[data-admin-delete]').forEach(btn => {
        btn.addEventListener('click', async (ev) => {
          ev.preventDefault(); ev.stopPropagation();
          if (!confirm('Delete this item?')) return;

          const itemPath = btn.getAttribute('data-admin-delete');
          if (!itemPath) return;
          const targetPage = btn.getAttribute('data-edit-page') || page;

          // Parse "solutionCards[2]" → arrayPath="solutionCards", index=2
          const match = itemPath.match(/^(.+)\[(\d+)\]$/);
          if (!match) return;
          const [, arrayPath, indexStr] = match;
          const index = parseInt(indexStr);

          const status = document.getElementById('adminStatus');
          if (status) { status.textContent = 'Deleting...'; status.style.color = '#fbbf24'; }

          const data = await fetchPageData(targetPage);
          if (!data) return;

          const arr = getByPath(data, arrayPath);
          if (!Array.isArray(arr) || index >= arr.length) return;
          arr.splice(index, 1);

          const saveRes = await fetch('/api/pages/' + targetPage, {
            method: 'PUT',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify(data),
          });

          if (saveRes.ok) {
            window.location.reload();
          } else if (status) {
            status.textContent = 'Delete failed'; status.style.color = '#f87171';
          }
        });
      });

      function getByPath(obj, pathStr) {
        const parts = pathStr.replace(/\[(\d+)\]/g, '.$1').split('.');
        let current = obj;
        for (const part of parts) {
          const key = isNaN(part) ? part : parseInt(part);
          current = current[key];
          if (current === undefined) return undefined;
        }
        return current;
      }

      function setByPath(obj, pathStr, value) {
        const parts = pathStr.replace(/\[(\d+)\]/g, '.$1').split('.');
        let current = obj;
        for (let i = 0; i < parts.length - 1; i++) {
          const key = isNaN(parts[i]) ? parts[i] : parseInt(parts[i]);
          if (current[key] === undefined || current[key] === null) current[key] = {};
          current = current[key];
        }
        const lastKey = isNaN(parts[parts.length - 1]) ? parts[parts.length - 1] : parseInt(parts[parts.length - 1]);
        current[lastKey] = value;
      }
    });
  </script>
)}
