---
/**
 * ProductGrid - 제품 카드 그리드 (섹션 그룹 + 플랫 아이템 지원)
 * sections 배열이 있으면 섹션별로 그룹 렌더링, 없으면 기존 flat items 렌더링
 */
import { Image } from 'astro:assets';

interface ProductItem {
  name: string;
  specs: string;
  image?: string;
  alt?: string;
  badge?: 'sil4' | 'new' | 'none';
}

interface SectionProduct {
  name: string;
  image?: string;
  features?: string[];
  badge?: 'sil4' | 'new' | 'none';
}

interface Section {
  title: string;
  products: SectionProduct[];
}

interface Props {
  items?: ProductItem[];
  sections?: Section[];
  isAdmin?: boolean;
  category?: string;
  userRole?: string;
  canViewDetails?: boolean;
}

const { items = [], sections, isAdmin = false, category = '', userRole = '', canViewDetails = false } = Astro.props;
// admin은 항상 보임, canViewDetails=true면 승인됨, 그 외 숨김
const hideDetails = !isAdmin && !canViewDetails;

// Load all product images from src/assets for Astro optimization
const allImages = import.meta.glob<{ default: ImageMetadata }>('/src/assets/images/products/*.{png,jpg,webp}', {
  eager: true,
});

function getImage(imagePath?: string): ImageMetadata | undefined {
  if (!imagePath) return undefined;
  const assetPath = imagePath.replace('/images/', '/src/assets/images/');
  return allImages[assetPath]?.default;
}

function e(p: string) {
  return isAdmin ? { 'data-edit': p } : {};
}
function img(p: string, preset: string) {
  return isAdmin ? { 'data-img': p, 'data-preset': preset } : {};
}

const hasSections = sections && sections.length > 0;
---

{/* ===== 섹션 기반 렌더링 ===== */}
{hasSections && sections.map((section, si) => (
  <div class="cat-section" style="position:relative;">
    {isAdmin && (
      <button class="admin-delete-btn" data-admin-delete={`sections[${si}]`} title="Delete Section">
        &times;
      </button>
    )}
    <h2 class="cat-section-title" translate="no" id={`section-${si}`} {...e(`sections[${si}].title`)}
      data-i18n={`ps.${category}.s${si}`}>{section.title}</h2>
    <div class="products-grid">
      {section.products.map((product, pi) => (
        <div class="p-card" style="position:relative;">
          {isAdmin && (
            <button class="admin-delete-btn" data-admin-delete={`sections[${si}].products[${pi}]`} title="Delete Product">
              &times;
            </button>
          )}
          <div class="p-img">
            {product.badge === 'sil4' && <span class="sale-badge">SIL4</span>}
            {product.badge === 'new' && <span class="new-badge">NEW</span>}
            {product.image ? (
              <img src={product.image} alt={product.name} loading="lazy"
                {...img(`sections[${si}].products[${pi}].image`, 'product')} />
            ) : isAdmin ? (
              <div class="p-img-empty"
                {...img(`sections[${si}].products[${pi}].image`, 'product')}
                style="width:100%;height:100%;position:absolute;top:0;left:0;display:flex;align-items:center;justify-content:center;color:#999;font-size:12px;cursor:pointer;">
                Click to add image
              </div>
            ) : (
              <div class="p-img-placeholder" />
            )}
          </div>
          <div class="p-name" translate="no" {...e(`sections[${si}].products[${pi}].name`)}
            data-i18n={`ps.${category}.s${si}p${pi}n`}>{product.name}</div>
          {hideDetails ? (
            <div class="p-locked">
              <span class="p-locked-icon">🔒</span>
              <span class="p-locked-text">승인된 사용자만 열람 가능</span>
            </div>
          ) : product.features && product.features.length > 0 && (
            <div class="p-detail-wrap">
              <button type="button" class="p-detail-toggle" aria-expanded="false">
                <span class="p-detail-toggle-text">Details</span>
                <svg class="p-detail-chevron" width="12" height="12" viewBox="0 0 12 12" fill="none" stroke="currentColor" stroke-width="2"><polyline points="2,4 6,8 10,4"></polyline></svg>
              </button>
              <ul class="p-features p-features--collapsed" {...e(`sections[${si}].products[${pi}].featuresHtml`)}>
                {product.features.map((f) => <li>{f}</li>)}
              </ul>
            </div>
          )}
        </div>
      ))}
    </div>
    {isAdmin && (
      <button
        class="admin-add-btn"
        data-admin-add={`sections[${si}].products`}
        data-admin-template='{"name":"New Product","image":"","features":["Feature 1"]}'
        style="margin-top:12px;"
      >
        + Add Product
      </button>
    )}
  </div>
))}

{/* Admin: 섹션 추가 버튼 */}
{isAdmin && hasSections && (
  <button
    class="admin-add-btn"
    data-admin-add="sections"
    data-admin-template='{"title":"New Section","products":[]}'
    style="margin-top:16px;"
  >
    + Add Section
  </button>
)}

{/* ===== 기존 flat items 렌더링 ===== */}
{items.length > 0 && (
  <>
    <div class="products-grid">
      {items.map((item, i) => {
        const optimized = getImage(item.image);
        const imgAttrs = isAdmin ? { 'data-img': `items[${i}].image`, 'data-preset': 'product' } : {};
        const editName = isAdmin ? { 'data-edit': `items[${i}].name` } : {};
        const editSpecs = isAdmin ? { 'data-edit': `items[${i}].specs` } : {};
        return (
          <div class="p-card" style="position:relative;">
            {isAdmin && (
              <button class="admin-delete-btn" data-admin-delete={`items[${i}]`} title="Delete">
                &times;
              </button>
            )}
            <div class="p-img">
              {item.badge === 'sil4' && <span class="sale-badge">SIL4</span>}
              {item.badge === 'new' && <span class="new-badge">NEW</span>}
              {optimized ? (
                <Image
                  src={optimized}
                  alt={item.alt || item.name}
                  loading="lazy"
                  width={400}
                  height={300}
                  {...imgAttrs}
                />
              ) : item.image ? (
                <img src={item.image} alt={item.alt || item.name} loading="lazy" {...imgAttrs} />
              ) : isAdmin ? (
                <div
                  class="p-img-empty"
                  {...imgAttrs}
                  style="width:100%;height:100%;position:absolute;top:0;left:0;display:flex;align-items:center;justify-content:center;color:#999;font-size:12px;cursor:pointer;"
                >
                  Click to add image
                </div>
              ) : null}
            </div>
            <div class="p-name" translate="no" {...editName}>
              {item.name}
            </div>
            {hideDetails ? (
              <div class="p-locked">
                <span class="p-locked-icon">🔒</span>
                <span class="p-locked-text">승인된 사용자만 열람 가능</span>
              </div>
            ) : (
              <div class="p-detail-wrap">
                <button type="button" class="p-detail-toggle" aria-expanded="false">
                  <span class="p-detail-toggle-text">Details</span>
                  <svg class="p-detail-chevron" width="12" height="12" viewBox="0 0 12 12" fill="none" stroke="currentColor" stroke-width="2"><polyline points="2,4 6,8 10,4"></polyline></svg>
                </button>
                <div class="p-price p-features--collapsed" {...editSpecs}>
                  {item.specs}
                </div>
              </div>
            )}
          </div>
        );
      })}
    </div>
    {isAdmin && (
      <button
        class="admin-add-btn"
        data-admin-add="items"
        data-admin-template='{"name":"New Product","specs":"Specifications here"}'
        style="margin-top:16px;"
      >
        + Add Product
      </button>
    )}
  </>
)}

<style>
  /* 섹션 제목 스타일 */
  .cat-section-title {
    font-size: 20px;
    margin: 40px 0 16px;
    padding: 10px 16px;
    background: var(--color-gray-200);
    border-left: 4px solid var(--color-black);
    border-radius: 4px;
    font-weight: 700;
  }
  .cat-section:first-child .cat-section-title {
    margin-top: 0;
  }

  /* 제품 그리드 */
  .products-grid {
    display: grid;
    grid-template-columns: repeat(4, minmax(0, 1fr));
    gap: var(--spacing-lg);
    align-items: start;
  }

  /* 제품 카드 */
  .p-card {
    position: relative;
    cursor: pointer;
    transition: transform var(--transition-slow);
  }
  .p-img {
    position: relative;
    overflow: hidden;
    background: var(--color-gray-200);
    padding-bottom: 75%;
  }
  /* telecom 페이지의 Server network appliance(s3) / Customized Network Appliance(s4)
     랙서버·스키매틱 이미지는 세로로 길게 표시 (다른 카테고리·섹션 무영향) */
  .cat-section:has(> [data-i18n="ps.telecom.s3"]) .p-img,
  .cat-section:has(> [data-i18n="ps.telecom.s4"]) .p-img {
    padding-bottom: 130%;
  }
  .p-img img,
  .p-img :global(img) {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: opacity var(--transition-slow);
  }
  .p-img-placeholder {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
  }

  /* 배지 */
  .sale-badge {
    position: absolute;
    top: 10px;
    right: 10px;
    background: var(--color-badge-bg);
    color: var(--color-white);
    font-size: var(--font-size-xs);
    padding: var(--spacing-xs) 10px;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    font-weight: 500;
    z-index: 1;
  }
  .new-badge {
    position: absolute;
    top: 10px;
    left: 10px;
    background: #2563eb;
    color: var(--color-white);
    font-size: var(--font-size-xs);
    padding: var(--spacing-xs) 10px;
    font-weight: 500;
    border-radius: 2px;
    z-index: 1;
  }

  /* 호버 효과 */
  @media (hover: hover) {
    .p-card:hover {
      transform: translateY(-4px);
    }
    .p-card:hover img,
    .p-card:hover :global(img) {
      opacity: 0.85;
    }
  }
  .p-card:active {
    transform: translateY(0) scale(0.98);
    transition: all var(--transition-fast);
  }

  /* 제품명 */
  .p-card .p-name {
    font-size: var(--font-size-xl);
    font-weight: 600;
    margin-top: 12px;
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
  }
  .p-card .p-price {
    font-size: var(--font-size-lg);
    margin-top: var(--spacing-xs);
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
  }

  /* 기능 목록 */
  .p-features {
    margin-top: 8px;
    padding: 0 0 0 16px;
    font-size: 14px;
    line-height: 1.7;
    color: #444;
    list-style: none;
    cursor: pointer;
    border-radius: 6px;
    transition: background 0.15s;
  }
  .p-features:hover {
    background: #f1f5f9;
  }
  .p-features li {
    position: relative;
    padding-left: 12px;
    padding-top: 2px;
    padding-bottom: 2px;
  }
  .p-features li::before {
    content: "\00B7";
    position: absolute;
    left: 0;
    color: #999;
    font-weight: 700;
  }

  /* 설명 확대 모달 오버레이 */
  .p-detail-overlay {
    display: none;
    position: fixed;
    top: 0;
    left: 0;
    width: 100vw;
    height: 100vh;
    background: rgba(0,0,0,0.5);
    z-index: 9999;
    justify-content: center;
    align-items: center;
    backdrop-filter: blur(2px);
  }
  .p-detail-overlay.active {
    display: flex;
  }
  .p-detail-modal {
    background: #fff;
    border-radius: 12px;
    padding: 32px 36px;
    max-width: 640px;
    width: 90%;
    max-height: 80vh;
    overflow-y: auto;
    box-shadow: 0 20px 60px rgba(0,0,0,0.25);
    animation: modalIn 0.25s ease-out;
  }
  .p-detail-modal-title {
    font-size: var(--font-size-2xl);
    font-weight: 700;
    margin-bottom: 16px;
    padding-bottom: 12px;
    border-bottom: 2px solid #e2e8f0;
    color: #1e293b;
  }
  .p-detail-modal-list {
    list-style: none;
    padding: 0;
    margin: 0;
    font-size: 16px;
    line-height: 1.8;
    color: #334155;
  }
  .p-detail-modal-list li {
    position: relative;
    padding: 6px 0 6px 18px;
    border-bottom: 1px solid #f1f5f9;
  }
  .p-detail-modal-list li:last-child {
    border-bottom: none;
  }
  .p-detail-modal-list li::before {
    content: "•";
    position: absolute;
    left: 0;
    color: #2563eb;
    font-weight: 700;
    font-size: 18px;
  }
  .p-detail-modal-close {
    position: absolute;
    top: 12px;
    right: 16px;
    background: none;
    border: none;
    font-size: 24px;
    color: #94a3b8;
    cursor: pointer;
    padding: 4px 8px;
    border-radius: 6px;
    transition: all 0.15s;
  }
  .p-detail-modal-close:hover {
    background: #f1f5f9;
    color: #334155;
  }
  @keyframes modalIn {
    from { opacity: 0; transform: scale(0.95) translateY(10px); }
    to { opacity: 1; transform: scale(1) translateY(0); }
  }

  /* specs (flat items) 확대 스타일 */
  .p-price {
    cursor: pointer;
    border-radius: 6px;
    transition: background 0.15s;
  }
  .p-price:hover {
    background: #f1f5f9;
  }

  /* 잠금 표시 */
  .p-locked {
    margin-top: 8px;
    padding: 8px 10px;
    background: #f8fafc;
    border: 1px dashed #cbd5e1;
    border-radius: 6px;
    text-align: center;
    font-size: 11px;
    color: #94a3b8;
  }
  .p-locked-icon { font-size: 14px; }
  .p-locked-text { display: block; margin-top: 2px; }

  /* ===== Detail Toggle ===== */
  .p-detail-wrap {
    margin-top: 6px;
  }
  .p-detail-toggle {
    display: inline-flex;
    align-items: center;
    gap: 4px;
    padding: 4px 10px;
    border: 1px solid #e2e8f0;
    border-radius: 6px;
    background: #f8fafc;
    color: #64748b;
    font-size: 11px;
    font-weight: 500;
    cursor: pointer;
    transition: all 0.15s;
    line-height: 1;
  }
  .p-detail-toggle:hover {
    background: #f1f5f9;
    color: #334155;
    border-color: #cbd5e1;
  }
  .p-detail-toggle[aria-expanded="true"] {
    background: #eff6ff;
    color: #2563eb;
    border-color: #bfdbfe;
  }
  .p-detail-chevron {
    transition: transform 0.2s;
    flex-shrink: 0;
  }
  .p-detail-toggle[aria-expanded="true"] .p-detail-chevron {
    transform: rotate(180deg);
  }
  .p-features--collapsed {
    display: none;
  }
  .p-features--expanded {
    display: block;
    animation: slideDown 0.2s ease-out;
  }
  @keyframes slideDown {
    from { opacity: 0; transform: translateY(-4px); }
    to { opacity: 1; transform: translateY(0); }
  }

  /* 반응형 */
  @media (max-width: 1024px) {
    .products-grid {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }
  }
  @media (max-width: 768px) {
    .products-grid {
      gap: var(--spacing-md);
    }
    .p-card .p-name {
      font-size: 15px;
      white-space: normal;
      line-height: 1.3;
    }
    .p-card .p-price {
      font-size: 13px;
      white-space: normal;
      line-height: 1.3;
    }
    .p-features {
      font-size: 12px;
    }
    .p-detail-modal {
      padding: 24px 20px;
    }
    .p-detail-modal-list {
      font-size: 14px;
    }
    .cat-section-title {
      font-size: 16px;
      margin: 24px 0 12px;
      padding: 8px 12px;
    }
  }
</style>

<!-- 확대 모달 오버레이 -->
<div class="p-detail-overlay" id="detailOverlay">
  <div class="p-detail-modal" style="position:relative;">
    <button class="p-detail-modal-close" id="detailModalClose">&times;</button>
    <div class="p-detail-modal-title" id="detailModalTitle"></div>
    <ul class="p-detail-modal-list" id="detailModalList"></ul>
  </div>
</div>

<script is:inline>
  // Detail toggle for product cards
  document.querySelectorAll('.p-detail-toggle').forEach(btn => {
    btn.addEventListener('click', (ev) => {
      ev.preventDefault();
      ev.stopPropagation();
      const wrap = btn.parentElement;
      if (!wrap) return;
      const content = wrap.querySelector('.p-features--collapsed, .p-features--expanded');
      if (!content) return;

      const isOpen = btn.getAttribute('aria-expanded') === 'true';
      if (isOpen) {
        btn.setAttribute('aria-expanded', 'false');
        content.classList.remove('p-features--expanded');
        content.classList.add('p-features--collapsed');
      } else {
        btn.setAttribute('aria-expanded', 'true');
        content.classList.remove('p-features--collapsed');
        content.classList.add('p-features--expanded');
      }
    });
  });

  // 설명칸 클릭 시 확대 모달
  const overlay = document.getElementById('detailOverlay');
  const modalTitle = document.getElementById('detailModalTitle');
  const modalList = document.getElementById('detailModalList');
  const modalClose = document.getElementById('detailModalClose');

  function openDetailModal(productName, items) {
    if (!overlay || !modalTitle || !modalList) return;
    modalTitle.textContent = productName;
    modalList.innerHTML = items.map(item => `<li>${item}</li>`).join('');
    overlay.classList.add('active');
    document.body.style.overflow = 'hidden';
  }

  function closeDetailModal() {
    if (!overlay) return;
    overlay.classList.remove('active');
    document.body.style.overflow = '';
  }

  // 관리자 모드일 때 모달 핸들러 아예 등록 안 함 (인라인 편집 우선)
  if (!document.getElementById('adminBar')) {
    // 섹션 기반 p-features (ul) 클릭
    document.querySelectorAll('.p-features').forEach(function(ul) {
      ul.addEventListener('click', function(ev) {
        ev.preventDefault();
        ev.stopPropagation();
        var card = ul.closest('.p-card');
        if (!card) return;
        var nameEl = card.querySelector('.p-name');
        var productName = nameEl ? nameEl.textContent.trim() : 'Product Details';
        var features = Array.from(ul.querySelectorAll('li')).map(function(li) { return li.textContent || ''; });
        openDetailModal(productName, features);
      });
    });

    // flat items p-price (specs) 클릭
    document.querySelectorAll('.p-price').forEach(function(el) {
      el.addEventListener('click', function(ev) {
        ev.preventDefault();
        ev.stopPropagation();
        var card = el.closest('.p-card');
        if (!card) return;
        var nameEl = card.querySelector('.p-name');
        var productName = nameEl ? nameEl.textContent.trim() : 'Product Details';
        var specs = el.textContent ? el.textContent.trim() : '';
        openDetailModal(productName, specs.split(/[,;]\s*|\n/).filter(Boolean));
      });
    });
  }

  // 모달 닫기
  modalClose?.addEventListener('click', closeDetailModal);
  overlay?.addEventListener('click', (ev) => {
    if (ev.target === overlay) closeDetailModal();
  });
  document.addEventListener('keydown', (ev) => {
    if (ev.key === 'Escape') closeDetailModal();
  });
</script>
