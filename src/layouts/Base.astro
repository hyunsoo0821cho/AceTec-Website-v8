---
/**
 * Base Layout - 모든 페이지의 공통 레이아웃
 * v7 index.html <head> + header + footer + scripts 통합
 */
import Header from '../components/Header.astro';
import MobileMenu from '../components/MobileMenu.astro';
import Footer from '../components/Footer.astro';
import BackToTop from '../components/BackToTop.astro';
import ChatWidget from '../components/ChatWidget.astro';

import '../styles/fonts.css';
import '../styles/tokens.css';
import '../styles/global.css';

interface Props {
  title: string;
  description?: string;
}

const {
  title,
  description = 'AceTec - Leading provider of embedded computing, industrial PCs, railway safety systems, and defense solutions for mission-critical applications.',
} = Astro.props;
const currentPath = Astro.url.pathname;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover" />
    <meta name="description" content={description} />
    <meta name="theme-color" content="#0a0a0a" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta name="robots" content="index, follow" />
    <meta
      name="keywords"
      content="embedded computing, industrial PC, VPX, VME, HIMA railway, defense solutions, HPC, RTOS, sensor simulation"
    />
    <link rel="canonical" href="https://www.acetronix.co.kr" />
    <title>{title}</title>
    <link
      rel="icon"
      type="image/svg+xml"
      href="data:image/svg+xml,<svg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 100 100'><rect width='100' height='100' rx='12' fill='%230a0a0a'/><text x='50' y='68' text-anchor='middle' font-size='60' font-weight='700' fill='white' font-family='sans-serif'>A</text></svg>"
    />
    <!-- Fonts self-hosted: see src/styles/fonts.css -->
  </head>
  <body>
    <a href="#main-content" class="skip-link">Skip to content</a>

    <Header currentPath={currentPath} />
    <MobileMenu currentPath={currentPath} />

    <main id="main-content">
      <slot />
    </main>

    <Footer />
    <BackToTop />
    <ChatWidget />

    <script>
      // Mobile menu toggle
      const hamburger = document.getElementById('hamburgerBtn');
      const mobileMenu = document.getElementById('mobileMenu');

      function toggleMenu() {
        if (!hamburger || !mobileMenu) return;
        const isOpen = mobileMenu.classList.toggle('open');
        hamburger.classList.toggle('open');
        hamburger.setAttribute('aria-expanded', isOpen ? 'true' : 'false');
        hamburger.setAttribute('aria-label', isOpen ? 'Close menu' : 'Open menu');
        mobileMenu.setAttribute('aria-hidden', isOpen ? 'false' : 'true');
        if (isOpen) {
          mobileMenu.removeAttribute('inert');
        } else {
          mobileMenu.setAttribute('inert', '');
        }
        document.body.classList.toggle('no-scroll', isOpen);

        if (isOpen) {
          const firstLink = mobileMenu.querySelector('.mob-link');
          if (firstLink) setTimeout(() => (firstLink as HTMLElement).focus(), 100);
        }
      }

      function closeMenu() {
        if (!hamburger || !mobileMenu || !mobileMenu.classList.contains('open')) return;
        mobileMenu.classList.remove('open');
        hamburger.classList.remove('open');
        hamburger.setAttribute('aria-expanded', 'false');
        hamburger.setAttribute('aria-label', 'Open menu');
        mobileMenu.setAttribute('aria-hidden', 'true');
        mobileMenu.setAttribute('inert', '');
        document.body.classList.remove('no-scroll');
      }

      hamburger?.addEventListener('click', toggleMenu);

      // 모바일 메뉴 닫기 버튼 (모바일 미리보기용)
      document.getElementById('mobileMenuClose')?.addEventListener('click', closeMenu);

      // Close menu when a link inside mobile menu is clicked (v7 router.js closeMenu pattern)
      mobileMenu?.querySelectorAll('a').forEach((link) => {
        link.addEventListener('click', () => closeMenu());
      });

      // Escape key + Focus trap
      document.addEventListener('keydown', (e) => {
        if (!mobileMenu?.classList.contains('open')) return;

        if (e.key === 'Escape') {
          closeMenu();
          hamburger?.focus();
          return;
        }

        if (e.key === 'Tab') {
          const focusable = mobileMenu.querySelectorAll<HTMLElement>('a, button, [tabindex]:not([tabindex="-1"])');
          if (focusable.length === 0) return;
          const first = focusable[0];
          const last = focusable[focusable.length - 1];

          if (e.shiftKey) {
            if (document.activeElement === first) {
              e.preventDefault();
              last.focus();
            }
          } else {
            if (document.activeElement === last) {
              e.preventDefault();
              first.focus();
            }
          }
        }
      });

      // Header scroll shadow + Back to top
      const header = document.getElementById('mainHeader');
      const backBtn = document.querySelector<HTMLElement>('.back-to-top');
      let ticking = false;

      window.addEventListener('scroll', () => {
        if (ticking) return;
        ticking = true;
        requestAnimationFrame(() => {
          const scrollY = window.scrollY;
          header?.classList.toggle('scrolled', scrollY > 50);
          backBtn?.classList.toggle('visible', scrollY > 500);
          ticking = false;
        });
      });

      backBtn?.addEventListener('click', () => {
        window.scrollTo({ top: 0, behavior: 'smooth' });
      });

      // Toast notification
      const TOAST_DURATION = 2500;
      const TOAST_FADE = 300;

      function showToast(msg: string, isError = false) {
        const existing = document.querySelector('.toast-msg');
        if (existing) existing.remove();

        const toast = document.createElement('div');
        toast.className = 'toast-msg ' + (isError ? 'toast-msg--error' : 'toast-msg--success');
        toast.textContent = msg;
        toast.setAttribute('role', 'alert');
        toast.setAttribute('aria-live', 'polite');
        document.body.appendChild(toast);

        requestAnimationFrame(() => toast.classList.add('visible'));

        setTimeout(() => {
          toast.classList.remove('visible');
          setTimeout(() => toast.remove(), TOAST_FADE);
        }, TOAST_DURATION);
      }

      // Contact form validation + submission
      const EMAIL_REGEX = /^[^\s@]+@[^\s@]+\.[^\s@]+$/;

      function validateField(input: HTMLInputElement | HTMLTextAreaElement): boolean {
        const fg = input.closest('.fg');
        if (!input.value.trim()) {
          fg?.classList.add('has-error');
          return false;
        }
        if (input.type === 'email' && !EMAIL_REGEX.test(input.value.trim())) {
          fg?.classList.add('has-error');
          return false;
        }
        fg?.classList.remove('has-error');
        return true;
      }

      // Contact form: data-action="submit" click handler (v7 forms.js pattern)
      document.addEventListener('click', (e) => {
        const el = (e.target as HTMLElement).closest('[data-action="submit"]') as HTMLButtonElement;
        if (!el) return;
        e.preventDefault();

        const wrapper = el.closest('form') || el.closest('.contact-grid') || el.closest('.container');
        if (!wrapper) return;

        const inputs = wrapper.querySelectorAll<HTMLInputElement | HTMLTextAreaElement>(
          'input:not([type=checkbox]), textarea',
        );
        let valid = true;
        let firstError: HTMLElement | null = null;

        inputs.forEach((input) => {
          if (!validateField(input)) {
            valid = false;
            if (!firstError) firstError = input;
          }
        });

        if (!valid) {
          showToast('Please fill in all required fields.', true);
          firstError?.focus();
          return;
        }

        // 폼 데이터 수집
        const formData: Record<string, string> = {};
        inputs.forEach((input) => {
          const label = input.closest('.fg')?.querySelector('label')?.textContent?.trim() || input.id;
          formData[label] = input.value;
        });

        // 이름 필드 찾기
        const fnameEl = wrapper.querySelector('[id$="-fname"]') as HTMLInputElement;
        const lnameEl = wrapper.querySelector('[id$="-lname"]') as HTMLInputElement;
        const emailEl = wrapper.querySelector('[id$="-email"]') as HTMLInputElement;
        const phoneEl = wrapper.querySelector('[id$="-phone"]') as HTMLInputElement;
        const msgEl = wrapper.querySelector('textarea') as HTMLTextAreaElement;
        const name = ((fnameEl?.value || '') + ' ' + (lnameEl?.value || '')).trim();
        const senderEmail = emailEl?.value || '';
        const phone = phoneEl?.value || '';
        const message = msgEl?.value || '';

        const to = 'acetec@acetec-korea.co.kr';
        const subjectText = '[AceTec 문의] ' + name + ' - 제품 문의';
        const bodyText =
          '성명: ' + name + '\n' +
          '이메일: ' + senderEmail + '\n' +
          (phone ? '전화번호: ' + phone + '\n' : '') +
          '\n' + message;

        // Gmail / Outlook 선택 모달
        let overlay = document.getElementById('emailChoiceOverlay');
        if (!overlay) {
          overlay = document.createElement('div');
          overlay.id = 'emailChoiceOverlay';
          overlay.innerHTML = `
            <div class="email-choice-modal">
              <h3>이메일 앱 선택</h3>
              <p>어떤 이메일로 보내시겠습니까?</p>
              <div class="email-choice-btns">
                <button data-choice="gmail" class="email-choice-btn gmail-btn">
                  <svg width="20" height="20" viewBox="0 0 24 24" fill="none"><path d="M20 4H4a2 2 0 0 0-2 2v12a2 2 0 0 0 2 2h16a2 2 0 0 0 2-2V6a2 2 0 0 0-2-2z" stroke="currentColor" stroke-width="2"/><path d="m2 6 10 7L22 6" stroke="currentColor" stroke-width="2"/></svg>
                  Gmail
                </button>
                <button data-choice="outlook" class="email-choice-btn outlook-btn">
                  <svg width="20" height="20" viewBox="0 0 24 24" fill="none"><path d="M20 4H4a2 2 0 0 0-2 2v12a2 2 0 0 0 2 2h16a2 2 0 0 0 2-2V6a2 2 0 0 0-2-2z" stroke="currentColor" stroke-width="2"/><path d="m2 6 10 7L22 6" stroke="currentColor" stroke-width="2"/></svg>
                  Outlook
                </button>
              </div>
              <button class="email-choice-cancel">취소</button>
            </div>
          `;
          document.body.appendChild(overlay);

          // 스타일 삽입
          if (!document.getElementById('emailChoiceStyle')) {
            const style = document.createElement('style');
            style.id = 'emailChoiceStyle';
            style.textContent = `
              #emailChoiceOverlay { position:fixed;inset:0;background:rgba(0,0,0,0.5);z-index:99999;display:flex;align-items:center;justify-content:center;opacity:0;pointer-events:none;transition:opacity 0.2s; }
              #emailChoiceOverlay.open { opacity:1;pointer-events:auto; }
              .email-choice-modal { background:#fff;border-radius:16px;padding:32px;width:90%;max-width:400px;text-align:center;box-shadow:0 20px 60px rgba(0,0,0,0.15); }
              .email-choice-modal h3 { font-size:20px;font-weight:700;margin-bottom:8px; }
              .email-choice-modal p { color:#64748b;font-size:14px;margin-bottom:24px; }
              .email-choice-btns { display:flex;gap:12px;margin-bottom:16px; }
              .email-choice-btn { flex:1;display:flex;align-items:center;justify-content:center;gap:8px;padding:14px;border:2px solid #e2e8f0;border-radius:12px;background:#fff;font-size:15px;font-weight:600;cursor:pointer;transition:all 0.15s;font-family:inherit; }
              .gmail-btn:hover { border-color:#ea4335;color:#ea4335;background:#fef2f2; }
              .outlook-btn:hover { border-color:#0078d4;color:#0078d4;background:#eff6ff; }
              .email-choice-cancel { background:none;border:none;color:#94a3b8;font-size:14px;cursor:pointer;font-family:inherit; }
              .email-choice-cancel:hover { color:#475569; }
            `;
            document.head.appendChild(style);
          }
        }

        overlay.classList.add('open');

        const handleChoice = (ev: Event) => {
          const btn = (ev.target as HTMLElement).closest('[data-choice]');
          const cancel = (ev.target as HTMLElement).closest('.email-choice-cancel');

          if (cancel) {
            overlay!.classList.remove('open');
            overlay!.removeEventListener('click', handleChoice);
            return;
          }
          if (!btn) return;
          const choice = btn.getAttribute('data-choice');
          overlay!.classList.remove('open');
          overlay!.removeEventListener('click', handleChoice);

          if (choice === 'gmail') {
            const gmailUrl = 'https://mail.google.com/mail/?view=cm'
              + '&to=' + encodeURIComponent(to)
              + '&su=' + encodeURIComponent(subjectText)
              + '&body=' + encodeURIComponent(bodyText);
            window.open(gmailUrl, '_blank');
          } else {
            window.location.href = 'mailto:' + to
              + '?subject=' + encodeURIComponent(subjectText)
              + '&body=' + encodeURIComponent(bodyText);
          }

          el.textContent = 'SENT!';
          el.classList.add('btn-sent');
          showToast('이메일 앱이 열렸습니다. 전송을 완료해주세요.');
          setTimeout(() => {
            el.textContent = el.getAttribute('data-original') || 'SUBMIT';
            el.classList.remove('btn-sent');
          }, 3000);
        };
        overlay.addEventListener('click', handleChoice);
      });

      // data-action="submit" keyboard support (Enter key)
      document.addEventListener('keydown', (e) => {
        if ((e as KeyboardEvent).key !== 'Enter') return;
        const el = (e.target as HTMLElement).closest('[data-action="submit"]');
        if (el) (el as HTMLElement).click();
      });

      // Clear error on input
      document.addEventListener('input', (e) => {
        const input = e.target as HTMLElement;
        if (!input.matches('.fg input, .fg textarea')) return;
        const fg = input.closest('.fg');
        if (fg && (input as HTMLInputElement).value.trim()) {
          fg.classList.remove('has-error');
        }
      });

      // data-action dispatcher (v7 forms.js actionHandlers)
      const MESSAGES = {
        SIGNUP_SOON: 'Sign up coming soon!',
        SOCIAL: 'Follow us on social media!',
        SOCIAL_OPEN: 'Opening social media...',
        APP_SOON: 'Application details coming soon!',
        LESSON_SOON: 'Details coming soon!',
      };

      const actionHandlers: Record<string, (e: Event, el: HTMLElement) => void> = {
        signup: (e) => {
          e.preventDefault();
          showToast(MESSAGES.SIGNUP_SOON);
        },
        social: (e) => {
          e.preventDefault();
          showToast(MESSAGES.SOCIAL);
        },
        'start-app': (e) => {
          e.preventDefault();
          showToast(MESSAGES.APP_SOON);
        },
        lesson: () => {
          showToast(MESSAGES.LESSON_SOON);
        },
      };

      document.addEventListener('click', (e) => {
        const el = (e.target as HTMLElement).closest('[data-action]') as HTMLElement;
        if (!el) return;
        const action = el.getAttribute('data-action');
        if (action && actionHandlers[action]) actionHandlers[action](e, el);
      });

      document.addEventListener('keydown', (e) => {
        if ((e as KeyboardEvent).key !== 'Enter') return;
        const el = (e.target as HTMLElement).closest('[data-action="lesson"]');
        if (el) showToast(MESSAGES.LESSON_SOON);
      });

      // Partner logo click toast (v7 scroll-effects.js)
      const socialGrid = document.querySelector('.social-grid');
      if (socialGrid) {
        socialGrid.addEventListener('click', (e) => {
          if ((e.target as HTMLElement).tagName === 'IMG') showToast(MESSAGES.SOCIAL_OPEN);
        });
        socialGrid.addEventListener('keydown', (e) => {
          if ((e as KeyboardEvent).key === 'Enter' && (e.target as HTMLElement).tagName === 'IMG') {
            showToast(MESSAGES.SOCIAL_OPEN);
          }
        });
      }
    </script>

    <!-- 제품 이미지 확대/축소 Lightbox -->
    <div id="imgLightbox" style="display:none;position:fixed;inset:0;z-index:999999;background:rgba(0,0,0,0.85);cursor:zoom-out;justify-content:center;align-items:center;">
      <img id="imgLightboxImg" style="max-width:90vw;max-height:90vh;object-fit:contain;transform-origin:center;transition:transform 0.2s ease;" />
      <button id="imgLightboxClose" style="position:absolute;top:20px;right:24px;background:none;border:none;color:#fff;font-size:36px;cursor:pointer;line-height:1;">&times;</button>
    </div>
    <script>
      (function() {
        const lb = document.getElementById('imgLightbox');
        const lbImg = document.getElementById('imgLightboxImg') as HTMLImageElement;
        const lbClose = document.getElementById('imgLightboxClose');
        if (!lb || !lbImg || !lbClose) return;

        let scale = 1;
        let isDragging = false;
        let startX = 0, startY = 0, tx = 0, ty = 0, curTx = 0, curTy = 0;

        function openLb(src: string) {
          lbImg.src = src;
          scale = 1; tx = 0; ty = 0; curTx = 0; curTy = 0;
          lbImg.style.transform = 'scale(1) translate(0,0)';
          lb.style.display = 'flex';
          document.body.style.overflow = 'hidden';
        }
        function closeLb() {
          lb.style.display = 'none';
          lbImg.src = '';
          document.body.style.overflow = '';
        }
        function updateTransform() {
          lbImg.style.transform = `scale(${scale}) translate(${curTx}px,${curTy}px)`;
        }

        // .p-img 안의 img 클릭 시 확대
        document.addEventListener('click', (e) => {
          const target = e.target as HTMLElement;
          if (target.tagName === 'IMG' && target.closest('.p-img')) {
            e.preventDefault();
            e.stopPropagation();
            openLb((target as HTMLImageElement).src);
          }
        });

        // 닫기
        lbClose.addEventListener('click', closeLb);
        lb.addEventListener('click', (e) => {
          if (e.target === lb) closeLb();
        });
        document.addEventListener('keydown', (e) => {
          if (e.key === 'Escape' && lb.style.display === 'flex') closeLb();
        });

        // 마우스 휠 확대/축소
        lb.addEventListener('wheel', (e) => {
          e.preventDefault();
          const delta = (e as WheelEvent).deltaY > 0 ? -0.15 : 0.15;
          scale = Math.min(Math.max(0.5, scale + delta), 5);
          updateTransform();
        }, { passive: false });

        // 드래그 이동
        lbImg.addEventListener('mousedown', (e) => {
          if (scale <= 1) return;
          isDragging = true;
          startX = e.clientX; startY = e.clientY;
          tx = curTx; ty = curTy;
          lbImg.style.cursor = 'grabbing';
          e.preventDefault();
        });
        document.addEventListener('mousemove', (e) => {
          if (!isDragging) return;
          curTx = tx + (e.clientX - startX) / scale;
          curTy = ty + (e.clientY - startY) / scale;
          updateTransform();
        });
        document.addEventListener('mouseup', () => {
          isDragging = false;
          lbImg.style.cursor = '';
        });

        // 터치 핀치 줌
        let lastDist = 0;
        lb.addEventListener('touchstart', (e) => {
          const te = e as TouchEvent;
          if (te.touches.length === 2) {
            lastDist = Math.hypot(te.touches[0].clientX - te.touches[1].clientX, te.touches[0].clientY - te.touches[1].clientY);
          }
        });
        lb.addEventListener('touchmove', (e) => {
          const te = e as TouchEvent;
          if (te.touches.length === 2) {
            e.preventDefault();
            const dist = Math.hypot(te.touches[0].clientX - te.touches[1].clientX, te.touches[0].clientY - te.touches[1].clientY);
            const delta = (dist - lastDist) * 0.005;
            scale = Math.min(Math.max(0.5, scale + delta), 5);
            lastDist = dist;
            updateTransform();
          }
        }, { passive: false });
      })();
    </script>

    <!-- ===== Desktop / Mobile Preview Toggle ===== -->
    <div id="view-toggle-toolbar" role="toolbar" aria-label="View mode toggle">
      <button id="desktop-view-btn" class="view-btn active" data-view="desktop" aria-pressed="true" title="Desktop view">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <rect x="2" y="3" width="20" height="14" rx="2" ry="2"></rect>
          <line x1="8" y1="21" x2="16" y2="21"></line>
          <line x1="12" y1="17" x2="12" y2="21"></line>
        </svg>
      </button>
      <button id="mobile-view-btn" class="view-btn" data-view="mobile" aria-pressed="false" title="Mobile view">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <rect x="5" y="2" width="14" height="20" rx="2" ry="2"></rect>
          <line x1="12" y1="18" x2="12.01" y2="18"></line>
        </svg>
      </button>
    </div>

    <style is:global>
      /* ===== View Toggle Toolbar ===== */
      #view-toggle-toolbar {
        position: fixed;
        bottom: 24px;
        right: 24px;
        z-index: 99998;
        display: flex;
        gap: 4px;
        background: #fff;
        border-radius: 12px;
        padding: 4px;
        box-shadow: 0 4px 20px rgba(0,0,0,0.12);
        border: 1px solid #e5e5e5;
      }
      .view-btn {
        display: flex;
        align-items: center;
        justify-content: center;
        width: 40px;
        height: 40px;
        border: none;
        border-radius: 8px;
        background: transparent;
        color: #999;
        cursor: pointer;
        transition: all 0.15s;
      }
      .view-btn:hover { background: #f5f5f5; color: #333; }
      .view-btn.active { background: #e5e5e5; color: #000; }

      /* 실제 모바일(768px 이하)에서는 토글 불필요 → 숨김 */
      @media (max-width: 768px) {
        #view-toggle-toolbar { display: none !important; }
      }

      /* ================================================= */
      /* ===== MOBILE PREVIEW MODE — 클래스 기반 시뮬레이션 ===== */
      /* ================================================= */

      body.mobile-preview-mode {
        background: #e5e7eb !important;
        display: flex !important;
        flex-direction: column !important;
        align-items: center !important;
        min-height: 100vh !important;
      }

      /* 모든 직계 자식을 390px 폭으로 제한 */
      body.mobile-preview-mode > * {
        max-width: 390px !important;
        width: 100% !important;
        margin-left: auto !important;
        margin-right: auto !important;
      }

      /* 툴바는 제한 해제 */
      body.mobile-preview-mode > #view-toggle-toolbar {
        max-width: none !important;
        width: auto !important;
      }

      /* Skip link */
      body.mobile-preview-mode > .skip-link {
        max-width: none !important;
      }

      /* ===== Header ===== */
      body.mobile-preview-mode .header {
        max-width: 390px !important;
        width: 100% !important;
        position: sticky !important;
        top: 0 !important;
      }
      body.mobile-preview-mode .nav-right { display: none !important; }
      body.mobile-preview-mode .hamburger { display: flex !important; }
      body.mobile-preview-mode .mega-menu { display: none !important; }

      /* ===== Main content ===== */
      body.mobile-preview-mode main {
        max-width: 390px !important;
        width: 100% !important;
        background: #fff !important;
        overflow-x: hidden !important;
      }

      /* ===== Hero ===== */
      body.mobile-preview-mode .hero {
        height: 60vh !important;
        min-height: 400px !important;
        max-height: 500px !important;
        margin-top: -60px !important;
        padding-top: 60px !important;
      }
      body.mobile-preview-mode .hero-content {
        padding: 0 20px 40px !important;
