    <script>
      // Desktop / Mobile preview toggle (localStorage로 페이지 이동 시 모드 유지)
      const desktopBtn = document.getElementById('desktop-view-btn');
      const mobileBtn = document.getElementById('mobile-view-btn');

      function switchView(mode: string, scroll = true) {
        if (!desktopBtn || !mobileBtn) return;
        if (mode === 'mobile') {
          document.body.classList.add('mobile-preview-mode');
          desktopBtn.classList.remove('active');
          mobileBtn.classList.add('active');
          mobileBtn.setAttribute('aria-pressed', 'true');
          desktopBtn.setAttribute('aria-pressed', 'false');
        } else {
          document.body.classList.remove('mobile-preview-mode');
          desktopBtn.classList.add('active');
          mobileBtn.classList.remove('active');
          desktopBtn.setAttribute('aria-pressed', 'true');
          mobileBtn.setAttribute('aria-pressed', 'false');
        }
        try { localStorage.setItem('viewMode', mode); } catch {}
        if (scroll) window.scrollTo(0, 0);
      }

      desktopBtn?.addEventListener('click', () => switchView('desktop'));
      mobileBtn?.addEventListener('click', () => switchView('mobile'));

      // 페이지 로드 시 저장된 모드 복원
      try {
        const saved = localStorage.getItem('viewMode');
        if (saved === 'mobile') switchView('mobile', false);
      } catch {}
    </script>
