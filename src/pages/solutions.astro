---
export const prerender = false;

import Base from '../layouts/Base.astro';
import ContactForm from '../components/ContactForm.astro';
import AdminInline from '../components/AdminInline.astro';
import { verifySession, getSessionIdFromCookie, getUserInfo } from '../lib/auth';
import fs from 'fs';
import path from 'path';
const cookie = Astro.request.headers.get('cookie');
const sessionId = verifySession(getSessionIdFromCookie(cookie));
const userInfo = sessionId ? getUserInfo(sessionId) : null;
const userRole = userInfo?.role || '';
const isAdmin = userRole === 'admin';
const root = process.cwd();
const d = JSON.parse(fs.readFileSync(path.join(root, 'src', 'content', 'pages', 'solutions.json'), 'utf-8'));
// Solutions 페이지는 자체 solutionCards 사용 (home과 독립)
const cards = d.solutionCards;
function e(p: string) {
  return isAdmin ? { 'data-edit': p } : {};
}
function img(p: string, preset: string) {
  return isAdmin ? { 'data-img': p, 'data-preset': preset } : {};
}

// href → i18n key mapping for solution cards
const hrefToKey: Record<string, string> = {
  '/products/military': 'military', '/products/railway': 'railway',
  '/products/industrial': 'automation', '/products/telecom': 'telecom',
  '/products/sensor': 'sensor', '/products/hpc': 'hpc',
  '/products/ipc': 'ipc', '/products/radar': 'radar',
  '/products/interconnect': 'interconnect',
};
function cardKey(href: string): string {
  return hrefToKey[href] || '';
}

// 서브카테고리 이름 → 대상 제품 페이지의 섹션 인덱스 매핑 (이름 기반 매칭)
const sectionIndexMap: Record<string, Record<string, number>> = {};
function loadSectionMap(href: string): Record<string, number> {
  if (sectionIndexMap[href]) return sectionIndexMap[href];
  const m = href.match(/^\/products\/(\w+)$/);
  if (!m) return {};
  try {
    const data = JSON.parse(fs.readFileSync(path.join(root, 'src', 'content', 'products', `${m[1]}.json`), 'utf-8'));
    const map: Record<string, number> = {};
    (data.sections || []).forEach((s: { title: string }, idx: number) => {
      if (s.title) map[s.title.trim().toLowerCase()] = idx;
    });
    sectionIndexMap[href] = map;
    return map;
  } catch {
    return {};
  }
}
function resolveSubcatHref(itemHref: string, subName: string, fallbackIndex: number): string {
  const map = loadSectionMap(itemHref);
  const matched = map[subName.trim().toLowerCase()];
  return `${itemHref}#section-${matched !== undefined ? matched : fallbackIndex}`;
}

---

<Base title="Solutions - AceTec">
  <AdminInline page="solutions" isAdmin={isAdmin} />

  <section class="section pt-page">
    <div class="container">
      <div class="svc-header-grid">
        <h1 class="text-6xl" {...e('title')} data-i18n="solutions.title">{d.title}</h1>
        <p class="text-lg" {...e('description')} data-i18n="solutions.desc">{d.description}</p>
      </div>
      <div class={`svc-cards ${isAdmin ? 'is-admin' : ''}`} {...(isAdmin ? { 'data-admin-sort': 'solutionCards' } : {})}>
        {
          cards.map((item: any, i: number) => (
            <div class="s-card" data-href={item.href || ''} {...(isAdmin ? { 'data-sort-id': String(i), draggable: 'true' } : {})} style="position:relative;">
              {isAdmin && (
                <button class="admin-delete-btn" data-admin-delete={`solutionCards[${i}]`} title="Delete">
                  &times;
                </button>
              )}
              <div class="s-card-img-wrap">
                {item.image ? (
                  <img
                    src={item.image}
                    alt={item.title}
                    loading="lazy"
                    {...img(`solutionCards[${i}].image`, 'service')}
                  />
                ) : (
                  <div class="img-placeholder" {...img(`solutionCards[${i}].image`, 'service')}>
                    Click to add image
                  </div>
                )}
                {item.href && <a href={item.href} class="s-card-img-link" aria-label={`Go to ${item.title}`}></a>}
              </div>
              {isAdmin && (
                <button type="button" class="pick-btn" data-pick-index={i} title="나만의 솔루션에 담기">♡</button>
              )}
              <h3 {...e(`solutionCards[${i}].title`)} {...((item.i18nKey || cardKey(item.href)) ? {'data-i18n': `solutionCards.${item.i18nKey || cardKey(item.href)}`} : {})}>{item.title}</h3>
              <div class="s-subtitle" {...e(`solutionCards[${i}].subtitle`)} {...((item.i18nKey || cardKey(item.href)) ? {'data-i18n': `solutionCards.${item.i18nKey || cardKey(item.href)}Sub`} : {})}>
                {item.subtitle}
              </div>
              <div class="s-content-area">
                <div class="s-tabs">
                  <button type="button" class="s-tab active" data-tab="desc" data-i18n="ui.descTab">설명</button>
                  <button type="button" class="s-tab" data-tab="cats" data-i18n="ui.catsTab">분야</button>
                </div>
                <div class="s-panel-wrap">
                  <div class="s-panel s-panel--desc active" data-panel="desc">
                    <p class="s-desc-full" {...e(`solutionCards[${i}].description`)} {...((item.i18nKey || cardKey(item.href)) ? {'data-i18n': `solutionCards.${item.i18nKey || cardKey(item.href)}Desc`} : {})}>{item.description}</p>
                  </div>
                  <div class="s-panel s-panel--cats" data-panel="cats">
                    {item.subcategories && item.subcategories.length > 0 && (
                      <ul class="s-subcats">
                        {item.subcategories.map((sub: string, si: number) => (
                          <li>
                            <a href={resolveSubcatHref(item.href, sub, si)} class="s-subcat-link" {...e(`solutionCards[${i}].subcategories[${si}]`)}>{sub}</a>
                            {isAdmin && (
                              <button class="subcat-delete-btn" data-admin-delete={`solutionCards[${i}].subcategories[${si}]`} title="Delete">&times;</button>
                            )}
                          </li>
                        ))}
                      </ul>
                    )}
                    {isAdmin && (
                      <button
                        class="admin-add-btn subcat-add-btn"
                        data-admin-add={`solutionCards[${i}].subcategories`}
                        data-admin-template='"New Item"'
                      >+ Add</button>
                    )}
                  </div>
                  <div class="s-resize-handle" title="Drag to resize"></div>
                </div>
              </div>
            </div>
          ))
        }
      </div>
      {
        isAdmin && (
          <button
            class="admin-add-btn"
            data-admin-add="solutionCards"
            data-admin-template='{"title":"New Solution","subtitle":"Description","description":"Details here","href":"/solutions","image":""}'
            style="margin-top:16px;"
          >
            + Add Solution
          </button>
        )
      }
    </div>
  </section>

  <section class="contact-bright section">
    <div class="container">
      <div class="contact-grid">
        <div class="contact-txt">
          <h2 {...e('quoteCta.title')} data-i18n="solutions.requestQuote">{d.quoteCta.title}</h2>
          <p {...e('quoteCta.description')} data-i18n="solutions.requestQuoteDesc">{d.quoteCta.description}</p>
        </div>
        <ContactForm prefix="svc" />
      </div>
    </div>
  </section>
</Base>

<script>
  // 카드 클릭 시 href로 이동 (인터랙티브 영역 제외)
  document.querySelectorAll('.s-card[data-href]').forEach(card => {
    card.addEventListener('click', (ev) => {
      const target = ev.target as HTMLElement;
      if (target.closest('.s-subcat-link') || target.closest('.admin-delete-btn') || target.closest('[data-edit]') || target.closest('[data-img]') || target.closest('.s-tab') || target.closest('.s-resize-handle') || target.closest('.s-panel') || target.closest('.pick-btn')) return;
      const href = card.getAttribute('data-href');
      if (href) window.location.href = href;
    });
  });

  // 탭 토글
  document.querySelectorAll('.s-content-area').forEach(area => {
    const tabs = area.querySelectorAll('.s-tab');
    const panels = area.querySelectorAll('.s-panel');
    tabs.forEach(tab => {
      tab.addEventListener('click', (ev) => {
        ev.stopPropagation();
        const t = (tab as HTMLElement).getAttribute('data-tab');
        tabs.forEach(b => b.classList.remove('active'));
        panels.forEach(p => p.classList.remove('active'));
        tab.classList.add('active');
        area.querySelector(`.s-panel[data-panel="${t}"]`)?.classList.add('active');
      });
    });
  });

  // 드래그 리사이즈
  document.querySelectorAll('.s-resize-handle').forEach(handle => {
    let startY = 0, startH = 0;
    const wrap = handle.parentElement as HTMLElement;

    function onMove(e: MouseEvent | TouchEvent) {
      e.preventDefault();
      const clientY = 'touches' in e ? e.touches[0].clientY : e.clientY;
      const newH = Math.max(60, Math.min(400, startH + (clientY - startY)));
      wrap.style.height = newH + 'px';
    }
    function onUp() {
      document.removeEventListener('mousemove', onMove as EventListener);
      document.removeEventListener('mouseup', onUp);
      document.removeEventListener('touchmove', onMove as EventListener);
      document.removeEventListener('touchend', onUp);
      document.body.style.userSelect = '';
      document.body.style.cursor = '';
    }
    function onDown(e: MouseEvent | TouchEvent) {
      e.preventDefault();
      e.stopPropagation();
      startY = 'touches' in e ? e.touches[0].clientY : e.clientY;
      startH = wrap.offsetHeight;
      document.body.style.userSelect = 'none';
      document.body.style.cursor = 'ns-resize';
      document.addEventListener('mousemove', onMove as EventListener);
      document.addEventListener('mouseup', onUp);
      document.addEventListener('touchmove', onMove as EventListener, { passive: false });
      document.addEventListener('touchend', onUp);
    }
    handle.addEventListener('mousedown', onDown as EventListener);
    handle.addEventListener('touchstart', onDown as EventListener, { passive: false });
  });

  // 홈에서 ?add=1 파라미터로 넘어왔을 때 자동으로 Add Solution 클릭
  // AdminInline의 data-admin-add 핸들러가 DOMContentLoaded에서 등록되므로 지연 실행
  if (new URLSearchParams(window.location.search).get('add') === '1') {
    setTimeout(() => {
      const addBtn = document.querySelector<HTMLButtonElement>('[data-admin-add="solutionCards"]');
      if (addBtn) {
        addBtn.click();
        history.replaceState(null, '', window.location.pathname);
      }
    }, 500);
  }

  // ===== 나만의 솔루션 담기 =====
  const PICK_KEY = 'acetec-my-solutions';
  const MAX_PICKS = 6;

  function getMyPicks(): number[] {
    try { return JSON.parse(localStorage.getItem(PICK_KEY) || '[]'); } catch { return []; }
  }
  function saveMyPicks(picks: number[]) {
    localStorage.setItem(PICK_KEY, JSON.stringify(picks));
  }

  function updatePickButtons() {
    const picks = getMyPicks();
    document.querySelectorAll<HTMLButtonElement>('.pick-btn').forEach(btn => {
      const idx = Number(btn.getAttribute('data-pick-index'));
      const picked = picks.includes(idx);
      btn.textContent = picked ? '♥' : '♡';
      btn.classList.toggle('picked', picked);
      btn.title = picked
        ? '나만의 솔루션에서 빼기'
        : picks.length >= MAX_PICKS ? `최대 ${MAX_PICKS}개까지 선택 가능` : '나만의 솔루션에 담기';
    });
    // 카운터
    let counter = document.getElementById('pickCounter');
    if (!counter) {
      counter = document.createElement('div');
      counter.id = 'pickCounter';
      counter.className = 'pick-counter';
      document.querySelector('.svc-header-grid')?.appendChild(counter);
    }
    counter.textContent = picks.length > 0 ? `담은 솔루션: ${picks.length}/${MAX_PICKS}` : '';
  }

  document.addEventListener('click', (e) => {
    const btn = (e.target as HTMLElement).closest('.pick-btn') as HTMLButtonElement;
    if (!btn) return;
    e.stopPropagation();
    const idx = Number(btn.getAttribute('data-pick-index'));
    let picks = getMyPicks();
    if (picks.includes(idx)) {
      picks = picks.filter(p => p !== idx);
    } else {
      if (picks.length >= MAX_PICKS) { alert(`최대 ${MAX_PICKS}개까지만 선택할 수 있습니다.`); return; }
      picks.push(idx);
    }
    saveMyPicks(picks);
    updatePickButtons();
  });

  updatePickButtons();
</script>

<style>
  .pick-btn {
    position: absolute; top: 10px; left: 10px; z-index: 5;
    width: 36px; height: 36px; border-radius: 50%;
    border: none; background: rgba(255,255,255,0.9); backdrop-filter: blur(4px);
    font-size: 20px; line-height: 1; cursor: pointer;
    transition: all 0.2s; box-shadow: 0 2px 8px rgba(0,0,0,0.15);
    color: #94a3b8;
  }
  .pick-btn:hover { transform: scale(1.15); background: #fff; }
  .pick-btn.picked { color: #ef4444; background: #fff; }
  .pick-counter {
    font-size: 14px; font-weight: 600; color: #2563eb;
    display: flex; align-items: flex-end; justify-content: flex-end;
  }
  .svc-header-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: var(--spacing-lg);
    margin-bottom: var(--spacing-3xl);
  }
  .svc-cards {
    display: grid;
    grid-template-columns: repeat(5, 1fr);
    gap: 14px;
  }
  .s-card {
    display: block;
    text-decoration: none;
    color: inherit;
    background: var(--color-gray-100);
    overflow: hidden;
    cursor: pointer;
    transition: box-shadow var(--transition-slow);
  }
  /* 관리자 모드: 인라인 편집 outline이 잘리지 않도록 overflow 해제 */
  .is-admin .s-card {
    overflow: visible;
  }
  .is-admin .s-desc {
    -webkit-line-clamp: unset;
    overflow: visible;
  }
  .s-card:hover {
    box-shadow: 0 4px 16px rgba(0, 0, 0, 0.1);
  }
  .s-card-img-wrap {
    position: relative;
  }
  .s-card img {
    width: 100%;
    aspect-ratio: 4/3;
    object-fit: cover;
    display: block;
    transition: opacity var(--transition-slow);
  }
  .s-card:hover img {
    opacity: 0.9;
  }
  .s-card-img-link {
    position: absolute;
    inset: 0;
    z-index: 5;
    cursor: pointer;
  }
  .s-card h3 {
    font-size: 25px;
    margin: 0;
    padding: 14px 14px 0;
    font-weight: 600;
    line-height: 1.3;
  }
  .s-card .s-subtitle {
    font-size: 20px;
    font-weight: 700;
    margin: 4px 0 8px;
    padding: 0 14px;
  }
  .s-card .s-desc {
    font-size: 16px;
    color: var(--color-gray-600);
    line-height: 1.5;
    padding: 0 14px 14px;
    margin: 0;
    display: -webkit-box;
    -webkit-line-clamp: 3;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  /* ===== Content Area: Tabs + Resizable Panel ===== */
  .s-content-area {
    padding: 0 14px 14px;
  }
  .s-tabs {
    display: flex;
    gap: 2px;
    margin-bottom: 0;
    border-bottom: 1px solid #e5e7eb;
  }
  .s-tab {
    flex: 1;
    padding: 6px 0;
    border: none;
    background: none;
    font-size: 12px;
    font-weight: 500;
    color: #94a3b8;
    cursor: pointer;
    border-bottom: 2px solid transparent;
    transition: all 0.15s;
    text-align: center;
  }
  .s-tab:hover { color: #475569; }
  .s-tab.active {
    color: #0f172a;
    border-bottom-color: #0f172a;
  }
  .s-panel-wrap {
    position: relative;
    height: 120px;
    min-height: 60px;
    max-height: 400px;
    overflow: hidden;
  }
  .s-panel {
    display: none;
    height: 100%;
    overflow-y: auto;
    padding-top: 8px;
    scrollbar-width: thin;
    scrollbar-color: #cbd5e1 transparent;
  }
  .s-panel::-webkit-scrollbar { width: 4px; }
  .s-panel::-webkit-scrollbar-thumb { background: #cbd5e1; border-radius: 2px; }
  .s-panel.active { display: block; }
  .s-desc-full {
    font-size: 14px;
    color: #64748b;
    line-height: 1.6;
    margin: 0;
  }
  .s-panel--cats .s-subcats {
    padding: 0;
  }

  /* Resize handle */
  .s-resize-handle {
    position: absolute;
    bottom: 0;
    left: 0;
    right: 0;
    height: 10px;
    cursor: ns-resize;
    display: flex;
    align-items: center;
    justify-content: center;
    background: linear-gradient(to top, rgba(255,255,255,1) 0%, rgba(255,255,255,0) 100%);
    z-index: 2;
  }
  .s-resize-handle::after {
    content: '';
    width: 32px;
    height: 3px;
    border-radius: 2px;
    background: #cbd5e1;
    transition: background 0.15s;
  }
  .s-resize-handle:hover::after {
    background: #94a3b8;
  }

  .s-subcats {
    margin: 0;
    padding: 0 14px 14px;
    list-style: none;
  }
  .s-subcats li {
    display: flex;
    align-items: center;
    gap: 6px;
    border-left: 2px solid var(--color-gray-300);
    padding: 3px 0 3px 10px;
  }
  .subcat-delete-btn {
    width: 18px;
    height: 18px;
    border-radius: 50%;
    border: none;
    background: #ef4444;
    color: #fff;
    font-size: 12px;
    line-height: 1;
    cursor: pointer;
    flex-shrink: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    opacity: 0;
    transition: opacity 0.15s;
  }
  .s-subcats li:hover .subcat-delete-btn { opacity: 1; }
  .subcat-delete-btn:hover { background: #dc2626; }
  .subcat-add-btn {
    margin: 8px 0 4px !important;
    font-size: 12px !important;
    padding: 4px 10px !important;
  }
  .s-subcats li:hover {
    border-left-color: var(--color-black);
  }
  .s-subcat-link {
    font-size: 14px;
    color: var(--color-gray-600);
    text-decoration: none;
    transition: color 0.15s;
  }
  .s-subcat-link:hover {
    color: var(--color-black);
  }
  .contact-bright {
    background: var(--color-bg-alt);
  }
  .contact-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: var(--spacing-5xl);
    align-items: start;
  }
  .contact-txt h2 {
    font-size: var(--font-size-6xl);
    margin-bottom: var(--spacing-lg);
  }
  .contact-txt p {
    font-size: var(--font-size-lg);
    line-height: 1.5;
  }

  @media (max-width: 1200px) {
    .svc-cards {
      grid-template-columns: repeat(3, 1fr);
    }
  }
  @media (max-width: 768px) {
    .svc-header-grid,
    .contact-grid {
      grid-template-columns: 1fr;
    }
    .svc-cards {
      grid-template-columns: repeat(2, 1fr);
    }
    .text-6xl {
      font-size: var(--font-size-5xl);
    }
  }
</style>
