---
import Base from '../layouts/Base.astro';
---

<Base title="Cart - AceTec">
  <section class="section pt-page-lg text-center min-h-60">
    <div class="container">
      <svg width="64" height="64" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" class="mb-xl cart-icon" aria-hidden="true"><circle cx="9" cy="21" r="1"></circle><circle cx="20" cy="21" r="1"></circle><path d="M1 1h4l2.68 13.39a2 2 0 0 0 2 1.61h9.72a2 2 0 0 0 2-1.61L23 6H6"></path></svg>
      <h1 class="heading-page">Your Cart</h1>
      <p class="heading-sub color-muted">Your inquiry cart is currently empty.</p>
      <a href="/solutions" class="btn-primary">BROWSE PRODUCTS</a>
    </div>
  </section>
</Base>

<style>
  .cart-icon { color: var(--color-gray-400); display: inline-block; }
</style>
