---
export const prerender = false;

import Base from '../layouts/Base.astro';
import ContactForm from '../components/ContactForm.astro';
import AdminInline from '../components/AdminInline.astro';
import { verifySession, getSessionIdFromCookie, getUserInfo } from '../lib/auth';
import fs from 'fs';
import path from 'path';
const cookie = Astro.request.headers.get('cookie');
const sessionId = verifySession(getSessionIdFromCookie(cookie));
const userInfo = sessionId ? getUserInfo(sessionId) : null;
const userRole = userInfo?.role || '';
const isAdmin = userRole === 'admin';
const root = process.cwd();
const d = JSON.parse(fs.readFileSync(path.join(root, 'src', 'content', 'pages', 'contact.json'), 'utf-8'));
function e(p: string) {
  return isAdmin ? { 'data-edit': p } : {};
}
function img(p: string, preset: string) {
  return isAdmin ? { 'data-img': p, 'data-preset': preset } : {};
}

const hq = d.offices[0];
const branch = d.offices[1];
---

<Base title="Contact Us - AceTec">
  <AdminInline page="contact" isAdmin={isAdmin} />

  <section class="section pt-page">
    <div class="container">
      <div class="contact-page-grid">
        <div>
          <h1 class="heading-page" {...e('title')} data-i18n="contact.title">{d.title}</h1>
          <p class="heading-sub-sm" {...e('subtitle')} data-i18n="contact.subtitle">{d.subtitle}</p>
          <ContactForm prefix="ct" />
          <div class="contact-offices">
            <div class="contact-office">
              <h3 {...e('offices[0].name')} data-i18n="contact.hqName">{hq.name}</h3>
              <p {...e('offices[0].address')}>{hq.address}</p>
              <ul class="contact-info-list">
                <li><a href={`mailto:${hq.email}`} class="link-underline" {...e('offices[0].email')}>{hq.email}</a></li>
                <li>
                  <a href={`tel:${hq.tel.replace(/-/g, '')}`} class="link-underline"
                    >TEL: <span {...e('offices[0].tel')}>{hq.tel}</span></a
                  >
                </li>
                <li>FAX: <span {...e('offices[0].fax')}>{hq.fax}</span></li>
              </ul>
            </div>
            <div class="contact-office">
              <h3 {...e('offices[1].name')} data-i18n="contact.branchName">{branch.name}</h3>
              <p {...e('offices[1].address')}>{branch.address}</p>
              <ul class="contact-info-list">
                <li>
                  <a href={`tel:${branch.tel.replace(/-/g, '')}`} class="link-underline"
                    >TEL: <span {...e('offices[1].tel')}>{branch.tel}</span></a
                  >
                </li>
                <li>FAX: <span {...e('offices[1].fax')}>{branch.fax}</span></li>
              </ul>
            </div>
          </div>
        </div>
        <div>
          <div class="overflow-hidden">
            <img
              src="/images/plans/plan-premium.png"
              alt="Contact us"
              class="img-cover"
              loading="lazy"
              {...img('image', 'hero')}
            />
          </div>
          {
            hq.directions && (
              <div class="contact-directions">
                <h4 data-i18n="contact.directions">Directions</h4>
                <p>
                  <strong data-i18n="contact.subway">Subway:</strong> <span {...e('offices[0].directions.subway')}>{hq.directions.subway}</span>
                </p>
                <p>
                  <strong data-i18n="contact.byCar">By car:</strong> <span {...e('offices[0].directions.car')}>{hq.directions.car}</span>
                </p>
              </div>
            )
          }
        </div>
      </div>
    </div>
  </section>
</Base>
<style>
  .contact-page-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: var(--spacing-3xl);
    align-items: start;
  }

  .contact-offices {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: var(--spacing-3xl);
    margin-top: var(--spacing-xl);
    margin-bottom: var(--spacing-3xl);
  }

  .contact-office h3 {
    font-size: var(--font-size-2xl);
    font-weight: 700;
    margin-bottom: var(--spacing-md);
  }

  .contact-office > p {
    font-size: var(--font-size-lg);
    color: var(--color-gray-700);
    line-height: 1.7;
    margin-bottom: var(--spacing-lg);
  }

  .contact-info-list {
    list-style: none;
    padding: 0;
    margin: 0 0 var(--spacing-lg) 0;
  }

  .contact-info-list li {
    font-size: var(--font-size-lg);
    color: var(--color-gray-700);
    padding: 6px 0;
  }

  .contact-directions {
    margin-top: var(--spacing-md);
    padding: var(--spacing-lg);
    background: var(--color-gray-100);
    border-radius: var(--radius-md);
  }

  .contact-directions h4 {
    font-size: var(--font-size-md);
    font-weight: 600;
    margin-bottom: var(--spacing-sm);
  }

  .contact-directions p {
    font-size: var(--font-size-base);
    color: var(--color-gray-700);
    line-height: 1.7;
    margin-bottom: var(--spacing-sm);
  }

  .contact-directions p:last-child {
    margin-bottom: 0;
  }

  /* 메일 서비스 선택 모달 */
  #mail-modal { display: none; }
  #mail-modal.active { display: block; }

  .mail-modal-backdrop {
    position: fixed; inset: 0;
    background: rgba(0,0,0,.5);
    z-index: 9998;
  }

  .mail-modal-content {
    position: fixed;
    top: 50%; left: 50%;
    transform: translate(-50%,-50%);
    background: #fff;
    border-radius: var(--radius-lg, 12px);
    padding: 32px;
    z-index: 9999;
    min-width: 340px;
    max-width: 420px;
    box-shadow: 0 20px 60px rgba(0,0,0,.25);
    text-align: center;
  }

  .mail-modal-content h3 {
    font-size: var(--font-size-xl, 20px);
    font-weight: 700;
    margin-bottom: 8px;
  }

  .mail-modal-content p {
    font-size: var(--font-size-base, 15px);
    color: var(--color-gray-600, #666);
    margin-bottom: 24px;
  }

  .mail-modal-buttons {
    display: flex;
    flex-direction: column;
    gap: 12px;
    margin-bottom: 20px;
  }

  .mail-btn {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 10px;
    padding: 14px 20px;
    border: 2px solid var(--color-gray-200, #e5e7eb);
    border-radius: var(--radius-md, 8px);
    background: #fff;
    font-size: 15px;
    font-weight: 600;
    cursor: pointer;
    transition: all .15s;
  }

  .mail-btn:hover { transform: translateY(-1px); box-shadow: 0 4px 12px rgba(0,0,0,.1); }
  .mail-btn-gmail:hover { border-color: #EA4335; color: #EA4335; }
  .mail-btn-naver:hover { border-color: #03C75A; color: #03C75A; }
  .mail-btn-outlook:hover { border-color: #0078D4; color: #0078D4; }

  .mail-modal-close {
    background: none;
    border: none;
    color: var(--color-gray-500, #888);
    font-size: 14px;
    cursor: pointer;
    padding: 8px 16px;
  }
  .mail-modal-close:hover { color: var(--color-gray-800, #333); }

  @media (max-width: 768px) {
    h1 {
      font-size: var(--font-size-5xl);
    }
    .contact-page-grid {
      grid-template-columns: 1fr;
    }
    .contact-page-grid .overflow-hidden {
      order: -1;
    }
    .contact-offices {
      grid-template-columns: 1fr;
    }
  }
</style>
<script>
  // 챗봇 문의 데이터 자동 입력
  document.addEventListener('DOMContentLoaded', () => {
    const raw = localStorage.getItem('acetec-inquiry');
    if (!raw) return;
    try {
      const data = JSON.parse(raw);
      localStorage.removeItem('acetec-inquiry');

      const form = document.querySelector('[data-contact-form="ct"]') as HTMLFormElement;
      if (!form) return;

      const fname = form.querySelector('#ct-fname') as HTMLInputElement;
      const lname = form.querySelector('#ct-lname') as HTMLInputElement;
      const email = form.querySelector('#ct-email') as HTMLInputElement;
      const phone = form.querySelector('#ct-phone') as HTMLInputElement;
      const msg = form.querySelector('#ct-msg') as HTMLTextAreaElement;

      if (fname && data.firstName) fname.value = data.firstName;
      if (lname && data.lastName) lname.value = data.lastName;
      if (email && data.email) email.value = data.email;
      if (phone && data.phone) phone.value = data.phone;
      if (msg) {
        const parts = [];
        if (data.product) parts.push('[관심 제품: ' + data.product + ']');
        if (data.message) parts.push(data.message);
        msg.value = parts.join('\n');
      }

      form.scrollIntoView({ behavior: 'smooth', block: 'center' });

      // 자동 채워진 알림
      const notice = document.createElement('div');
      notice.style.cssText = 'background:#eff6ff;border:1px solid #93c5fd;color:#1e40af;padding:12px 16px;border-radius:8px;font-size:13px;margin-bottom:16px;';
      notice.textContent = '✅ Contact Us 양식에 자동 작성되었습니다! 하단의 SUBMIT 버튼을 눌러 문의를 완료하세요.';
      form.insertBefore(notice, form.firstChild);
    } catch { /* ignore */ }
  });

  // SUBMIT 시 메일 서비스 선택 모달
  document.addEventListener('DOMContentLoaded', () => {
    const TO = 'acetec@acetec-korea.co.kr';
    const form = document.querySelector('[data-contact-form="ct"]') as HTMLFormElement;
    if (!form) return;

    const submitBtn = form.querySelector('[data-action="submit"]');
    if (!submitBtn) return;

    // 모달 생성
    const modal = document.createElement('div');
    modal.id = 'mail-modal';
    modal.innerHTML = `
      <div class="mail-modal-backdrop"></div>
      <div class="mail-modal-content">
        <h3>메일 서비스 선택</h3>
        <p>어떤 메일로 문의를 보내시겠습니까?</p>
        <div class="mail-modal-buttons">
          <button type="button" data-mail="gmail" class="mail-btn mail-btn-gmail">
            <svg viewBox="0 0 24 24" width="20" height="20" fill="none"><path d="M22 6c0-1.1-.9-2-2-2H4c-1.1 0-2 .9-2 2v12c0 1.1.9 2 2 2h16c1.1 0 2-.9 2-2V6zm-2 0l-8 5-8-5h16zm0 12H4V8l8 5 8-5v10z" fill="#EA4335"/></svg>
            Gmail
          </button>
          <button type="button" data-mail="naver" class="mail-btn mail-btn-naver">
            <svg viewBox="0 0 24 24" width="20" height="20"><rect width="24" height="24" rx="4" fill="#03C75A"/><text x="12" y="16.5" text-anchor="middle" fill="#fff" font-size="11" font-weight="bold">N</text></svg>
            네이버 메일
          </button>
          <button type="button" data-mail="outlook" class="mail-btn mail-btn-outlook">
            <svg viewBox="0 0 24 24" width="20" height="20" fill="none"><path d="M22 6c0-1.1-.9-2-2-2H4c-1.1 0-2 .9-2 2v12c0 1.1.9 2 2 2h16c1.1 0 2-.9 2-2V6zm-2 0l-8 5-8-5h16zm0 12H4V8l8 5 8-5v10z" fill="#0078D4"/></svg>
            Outlook
          </button>
        </div>
        <button type="button" class="mail-modal-close">취소</button>
      </div>
    `;
    document.body.appendChild(modal);

    let mailSubject = '';
    let mailBody = '';

    // SUBMIT 클릭 → 유효성 검사 → 모달 열기
    submitBtn.addEventListener('click', () => {
      const fname = (form.querySelector('#ct-fname') as HTMLInputElement)?.value.trim() || '';
      const lname = (form.querySelector('#ct-lname') as HTMLInputElement)?.value.trim() || '';
      const email = (form.querySelector('#ct-email') as HTMLInputElement)?.value.trim() || '';
      const phone = (form.querySelector('#ct-phone') as HTMLInputElement)?.value.trim() || '';
      const msg = (form.querySelector('#ct-msg') as HTMLTextAreaElement)?.value.trim() || '';

      if (!fname || !email || !msg) return;

      mailSubject = `[AceTec 문의] ${lname}${fname} - 제품 문의`;
      mailBody = `성명: ${lname} ${fname}\n이메일: ${email}\n전화번호: ${phone}\n\n${msg}`;
      modal.classList.add('active');
    });

    // 메일 서비스별 URL 생성 + 열기
    modal.addEventListener('click', (ev) => {
      const target = (ev.target as HTMLElement).closest('[data-mail]') as HTMLElement;
      if (!target) return;

      const service = target.dataset.mail;
      const s = encodeURIComponent(mailSubject);
      const b = encodeURIComponent(mailBody);
      let url = '';

      if (service === 'gmail') {
        url = `https://mail.google.com/mail/?view=cm&to=${TO}&su=${s}&body=${b}`;
      } else if (service === 'naver') {
        url = `https://mail.naver.com/write?to=${TO}&subject=${s}&body=${b}`;
      } else if (service === 'outlook') {
        url = `https://outlook.live.com/mail/0/deeplink/compose?to=${TO}&subject=${s}&body=${b}`;
      }

      if (url) window.open(url, '_blank');
      modal.classList.remove('active');
    });

    // 닫기
    modal.querySelector('.mail-modal-close')?.addEventListener('click', () => modal.classList.remove('active'));
    modal.querySelector('.mail-modal-backdrop')?.addEventListener('click', () => modal.classList.remove('active'));
  });
</script>
