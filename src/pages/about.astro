---
export const prerender = false;

import Base from '../layouts/Base.astro';
import ContactForm from '../components/ContactForm.astro';
import AdminInline from '../components/AdminInline.astro';
import { verifySession, getSessionIdFromCookie } from '../lib/auth';
import fs from 'fs';
import path from 'path';
const cookie = Astro.request.headers.get('cookie');
const isAdmin = !!verifySession(getSessionIdFromCookie(cookie));
const root = process.cwd();
const d = JSON.parse(fs.readFileSync(path.join(root, 'src', 'content', 'pages', 'about.json'), 'utf-8'));
function e(p: string) {
  return isAdmin ? { 'data-edit': p } : {};
}
function img(p: string, preset: string) {
  return isAdmin ? { 'data-img': p, 'data-preset': preset } : {};
}
---

<Base title="About Us - AceTec">
  <AdminInline page="about" isAdmin={isAdmin} />

  <section class="section pt-page">
    <div class="container">
      <div class="about-grid">
        <div class="about-txt">
          <h1 class="heading-page" {...e('whoWeAre.title')} data-i18n="about.whoWeAreTitle">{d.whoWeAre.title}</h1>
          {d.whoWeAre.paragraphs.map((p: string, i: number) => <p {...e(`whoWeAre.paragraphs[${i}]`)} data-i18n={`about.whoWeArePara${i + 1}`}>{p}</p>)}
        </div>
        <div class="overflow-hidden">
          <img
            src={d.whoWeAre.image || '/images/about/about-team.png'}
            alt="About AceTec team"
            class="img-tall"
            loading="lazy"
            {...img('whoWeAre.image', 'about')}
          />
        </div>
      </div>
    </div>
  </section>

  <section class="section about-stats-section">
    <div class="container">
      <div class="about-stats">
        {
          d.stats.map((s: any, i: number) => (
            <div class="stat-card">
              <span class="stat-number" {...e(`stats[${i}].number`)}>
                {s.number}
              </span>
              <span class="stat-label" {...e(`stats[${i}].label`)} data-i18n={`about.stats${['Years','Projects','Institutions','Partners'][i]}`}>
                {s.label}
              </span>
            </div>
          ))
        }
      </div>
    </div>
  </section>

  <section class="section about-ceo-section">
    <div class="container">
      <h2 class="about-section-title" {...e('ceo.title')} data-i18n="about.ceoGreeting">{d.ceo.title}</h2>
      <div class="ceo-grid">
        <div class="ceo-message">
          <p class="ceo-quote" {...e('ceo.quote')} data-i18n="about.ceoQuote">{d.ceo.quote}</p>
          {d.ceo.paragraphs.map((p: string, i: number) => <p {...e(`ceo.paragraphs[${i}]`)} data-i18n={`about.ceoPara${i + 1}`}>{p}</p>)}
          <p class="ceo-name" {...e('ceo.signature')} data-i18n="about.ceoSignature">{d.ceo.signature}</p>
        </div>
        <div class="ceo-highlights">
          <div class="highlight-card">
            <span class="highlight-icon"
              ><svg
                width="28"
                height="28"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="1.5"
                stroke-linecap="round"
                stroke-linejoin="round"
                ><path d="M6 9H4.5a2.5 2.5 0 0 1 0-5H6"></path><path d="M18 9h1.5a2.5 2.5 0 0 0 0-5H18"></path><path
                  d="M4 22h16"></path><path d="M10 14.66V17c0 .55-.47.98-.97 1.21C7.85 18.75 7 20.24 7 22"></path><path
                  d="M14 14.66V17c0 .55.47.98.97 1.21C16.15 18.75 17 20.24 17 22"></path><path
                  d="M18 2H6v7a6 6 0 0 0 12 0V2Z"></path></svg
              ></span
            >
            <h4 data-i18n="about.highlightFirstTitle">Korea's First</h4>
            <p data-i18n="about.highlightFirstDesc">Desktop-type fanless industrial PC with US-patented natural cooling technology</p>
          </div>
          <div class="highlight-card">
            <span class="highlight-icon"
              ><svg
                width="28"
                height="28"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="1.5"
                stroke-linecap="round"
                stroke-linejoin="round"
                ><path
                  d="M10 2v7.527a2 2 0 0 1-.211.896L4.72 20.55a1 1 0 0 0 .9 1.45h12.76a1 1 0 0 0 .9-1.45l-5.069-10.127A2 2 0 0 1 14 9.527V2"
                ></path><path d="M8.5 2h7"></path><path d="M7 16.5h10"></path></svg
              ></span
            >
            <h4 data-i18n="about.highlightRndTitle">Own R&amp;D Center</h4>
            <p data-i18n="about.highlightRndDesc">In-house research and development for custom embedded solutions</p>
          </div>
          <div class="highlight-card">
            <span class="highlight-icon"
              ><svg
                width="28"
                height="28"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="1.5"
                stroke-linecap="round"
                stroke-linejoin="round"
                ><path d="M12 22c5.523 0 10-4.477 10-10S17.523 2 12 2 2 6.477 2 12s4.477 10 10 10z"></path><path
                  d="m9 12 2 2 4-4"></path></svg
              ></span
            >
            <h4 data-i18n="about.highlightCertTitle">Certified Quality</h4>
            <p data-i18n="about.highlightCertDesc">ISO-9001, KC Certification, K Mark, SIL4 safety integrity</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <section class="section about-philosophy-section">
    <div class="container">
      <h2 class="about-section-title" {...e('philosophy.title')} data-i18n="about.philosophyTitle">{d.philosophy.title}</h2>
      <p class="about-section-sub" {...e('philosophy.subtitle')} data-i18n="about.philosophySub">{d.philosophy.subtitle}</p>
      <div class="philosophy-grid">
        {
          d.philosophy.items.map((item: any, i: number) => (
            <div class="philosophy-card">
              <div class="philosophy-number">{item.number}</div>
              <h3 {...e(`philosophy.items[${i}].title`)} data-i18n={`about.philosophy${i + 1}Title`}>{item.title}</h3>
              <p {...e(`philosophy.items[${i}].description`)} data-i18n={`about.philosophy${i + 1}Desc`}>{item.description}</p>
            </div>
          ))
        }
      </div>
    </div>
  </section>

  <section class="section about-culture-section">
    <div class="container">
      <h2 class="about-section-title" {...e('culture.title')} data-i18n="about.cultureTitle">{d.culture.title}</h2>
      <p class="about-section-sub" {...e('culture.subtitle')} data-i18n="about.cultureSub">{d.culture.subtitle}</p>
      <div class="culture-grid">
        {
          d.culture.items.map((item: any, i: number) => (
            <div class="culture-card">
              <div class="culture-icon">
                {i === 0 && (
                  <svg
                    width="32"
                    height="32"
                    viewBox="0 0 24 24"
                    fill="none"
                    stroke="currentColor"
                    stroke-width="1.5"
                    stroke-linecap="round"
                    stroke-linejoin="round"
                  >
                    <path d="M15 14c.2-1 .7-1.7 1.5-2.5 1-.9 1.5-2.2 1.5-3.5A6 6 0 0 0 6 8c0 1 .2 2.2 1.5 3.5.7.7 1.3 1.5 1.5 2.5" />
                    <path d="M9 18h6" />
                    <path d="M10 22h4" />
                  </svg>
                )}
                {i === 1 && (
                  <svg
                    width="32"
                    height="32"
                    viewBox="0 0 24 24"
                    fill="none"
                    stroke="currentColor"
                    stroke-width="1.5"
                    stroke-linecap="round"
                    stroke-linejoin="round"
                  >
                    <path d="M19 14c1.49-1.46 3-3.21 3-5.5A5.5 5.5 0 0 0 16.5 3c-1.76 0-3 .5-4.5 2-1.5-1.5-2.74-2-4.5-2A5.5 5.5 0 0 0 2 8.5c0 2.3 1.5 4.05 3 5.5l7 7Z" />
                  </svg>
                )}
                {i === 2 && (
                  <svg
                    width="32"
                    height="32"
                    viewBox="0 0 24 24"
                    fill="none"
                    stroke="currentColor"
                    stroke-width="1.5"
                    stroke-linecap="round"
                    stroke-linejoin="round"
                  >
                    <path d="M4.5 16.5c-1.5 1.26-2 5-2 5s3.74-.5 5-2c.71-.84.7-2.13-.09-2.91a2.18 2.18 0 0 0-2.91-.09z" />
                    <path d="m12 15-3-3a22 22 0 0 1 2-3.95A12.88 12.88 0 0 1 22 2c0 2.72-.78 7.5-6 11a22.35 22.35 0 0 1-4 2z" />
                    <path d="M9 12H4s.55-3.03 2-4c1.62-1.08 5 0 5 0" />
                    <path d="M12 15v5s3.03-.55 4-2c1.08-1.62 0-5 0-5" />
                  </svg>
                )}
              </div>
              <h3 {...e(`culture.items[${i}].title`)} data-i18n={`about.culture${i + 1}Title`}>{item.title}</h3>
              <p {...e(`culture.items[${i}].description`)} data-i18n={`about.culture${i + 1}Desc`}>{item.description}</p>
            </div>
          ))
        }
      </div>
    </div>
  </section>

  <section class="contact-bright section">
    <div class="container">
      <div class="contact-grid">
        <div class="contact-txt">
          <h2 {...e('partnerCta.title')} data-i18n="about.partnerCtaTitle">{d.partnerCta.title}</h2>
          <p {...e('partnerCta.description')} data-i18n="about.partnerCtaDesc">{d.partnerCta.description}</p>
        </div>
        <ContactForm prefix="abt" />
      </div>
    </div>
  </section>
</Base>
<style>
  .about-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: var(--spacing-3xl);
    align-items: start;
  }
  .about-txt p {
    font-size: var(--font-size-lg);
    line-height: 1.5;
  }
  .about-stats-section {
    background: var(--color-black);
    color: var(--color-white);
    padding: var(--spacing-5xl) 0;
  }
  .about-stats {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: var(--spacing-3xl);
    text-align: center;
  }
  .stat-card {
    display: flex;
    flex-direction: column;
    gap: var(--spacing-xs);
  }
  .stat-number {
    font-size: 48px;
    font-weight: 800;
    letter-spacing: -1px;
    line-height: 1;
  }
  .stat-label {
    font-size: var(--font-size-base);
    color: var(--color-gray-400);
    text-transform: uppercase;
    letter-spacing: 0.08em;
  }
  .about-ceo-section {
    background: var(--color-gray-100);
  }
  .about-section-title {
    font-size: var(--font-size-5xl);
    font-weight: 700;
    margin-bottom: var(--spacing-sm);
    text-align: center;
  }
  .about-section-sub {
    font-size: var(--font-size-lg);
    color: var(--color-gray-700);
    text-align: center;
    margin-bottom: var(--spacing-3xl);
  }
  .ceo-grid {
    display: grid;
    grid-template-columns: 1.5fr 1fr;
    gap: var(--spacing-3xl);
    align-items: start;
  }
  .ceo-message p {
    font-size: var(--font-size-lg);
    line-height: 1.7;
    margin-bottom: var(--spacing-md);
    color: var(--color-gray-800);
  }
  .ceo-quote {
    font-size: var(--font-size-2xl);
    font-weight: 600;
    font-style: italic;
    color: var(--color-black);
    border-left: 3px solid var(--color-black);
    padding-left: var(--spacing-lg);
    margin-bottom: var(--spacing-xl) !important;
  }
  .ceo-name {
    font-weight: 600;
    color: var(--color-black);
    margin-top: var(--spacing-lg) !important;
  }
  .ceo-highlights {
    display: flex;
    flex-direction: column;
    gap: var(--spacing-lg);
  }
  .highlight-card {
    background: var(--color-white);
    padding: var(--spacing-xl);
    border-radius: var(--radius-md);
    border: 1px solid var(--color-gray-200);
  }
  .highlight-card .highlight-icon {
    font-size: 28px;
    display: block;
    margin-bottom: var(--spacing-sm);
  }
  .highlight-card h4 {
    font-size: var(--font-size-md);
    font-weight: 700;
    margin-bottom: var(--spacing-xs);
  }
  .highlight-card p {
    font-size: var(--font-size-base);
    color: var(--color-gray-700);
    line-height: 1.5;
  }
  .about-philosophy-section {
    background: var(--color-white);
  }
  .philosophy-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: var(--spacing-xl);
  }
  .philosophy-card {
    padding: var(--spacing-xl);
    border: 1px solid var(--color-gray-200);
    border-radius: var(--radius-md);
    transition: box-shadow var(--transition-base);
  }
  .philosophy-card:hover {
    box-shadow: 0 4px 20px rgba(0, 0, 0, 0.08);
  }
  .philosophy-number {
    font-size: var(--font-size-4xl);
    font-weight: 800;
    color: var(--color-gray-300);
    margin-bottom: var(--spacing-sm);
  }
  .philosophy-card h3 {
    font-size: var(--font-size-xl);
    font-weight: 700;
    margin-bottom: var(--spacing-md);
  }
  .philosophy-card p {
    font-size: var(--font-size-base);
    line-height: 1.7;
    color: var(--color-gray-700);
  }
  .about-culture-section {
    background: var(--color-gray-100);
  }
  .culture-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: var(--spacing-xl);
  }
  .culture-card {
    background: var(--color-white);
    padding: var(--spacing-3xl) var(--spacing-xl);
    border-radius: var(--radius-md);
    text-align: center;
    transition: transform var(--transition-base);
  }
  .culture-card:hover {
    transform: translateY(-4px);
  }
  .culture-icon {
    font-size: 40px;
    margin-bottom: var(--spacing-md);
  }
  .culture-card h3 {
    font-size: var(--font-size-xl);
    font-weight: 700;
    margin-bottom: var(--spacing-md);
  }
  .culture-card p {
    font-size: var(--font-size-base);
    line-height: 1.7;
    color: var(--color-gray-700);
  }
  .contact-bright {
    background: var(--color-bg-alt);
  }
  .contact-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: var(--spacing-5xl);
    align-items: start;
  }
  .contact-txt h2 {
    font-size: var(--font-size-6xl);
    margin-bottom: var(--spacing-lg);
  }
  .contact-txt p {
    font-size: var(--font-size-lg);
    line-height: 1.5;
  }

  @media (max-width: 768px) {
    h1 {
      font-size: var(--font-size-5xl) !important;
    }
    .about-grid,
    .ceo-grid,
    .philosophy-grid,
    .culture-grid,
    .contact-grid {
      grid-template-columns: 1fr;
    }
    .about-stats {
      grid-template-columns: repeat(2, 1fr);
    }
    .stat-number {
      font-size: 36px;
    }
    .about-section-title {
      font-size: var(--font-size-4xl);
    }
  }
</style>
