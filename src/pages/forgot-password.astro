---
export const prerender = false;
import Base from '../layouts/Base.astro';
---

<Base title="비밀번호 재설정 - AceTec">
  <section class="reg-page">
    <!-- Step 1: 이메일 입력 -->
    <div id="fpStep1" class="reg-card">
      <h1>비밀번호 재설정</h1>
      <p class="reg-sub">등록된 회사 이메일을 입력하면 인증 코드를 보내드립니다</p>
      <div class="field">
        <label>회사 이메일</label>
        <div class="email-input-row">
          <input type="text" id="fpEmailUser" placeholder="username" />
          <span class="email-domain">@acetec-korea.co.kr</span>
        </div>
      </div>
      <button class="btn-full" id="fpSendBtn">인증 코드 받기</button>
      <div id="fpMsg1" class="msg"></div>
      <div class="reg-footer">
        <a href="/login" class="link-back">← 로그인으로 돌아가기</a>
      </div>
    </div>

    <!-- Step 2: 코드 입력 + 새 비밀번호 -->
    <div id="fpStep2" class="reg-card" style="display:none;">
      <h1>새 비밀번호 설정</h1>
      <p class="reg-sub">이메일로 발송된 인증 코드와 새 비밀번호를 입력해주세요</p>
      <div class="field">
        <label>인증 코드</label>
        <input type="text" id="fpCode" placeholder="000000" maxlength="6" style="text-align:center;font-size:24px;letter-spacing:8px;" />
      </div>
      <div class="field">
        <label>새 비밀번호</label>
        <input type="password" id="fpNewPw" placeholder="6자 이상" />
      </div>
      <div class="field">
        <label>새 비밀번호 확인</label>
        <input type="password" id="fpNewPwConfirm" placeholder="비밀번호 재입력" />
      </div>
      <button class="btn-full" id="fpResetBtn">비밀번호 변경</button>
      <div id="fpMsg2" class="msg"></div>
      <div class="reg-footer">
        <button class="link-back" id="fpBack">← 돌아가기</button>
      </div>
    </div>

    <!-- Step 3: 완료 -->
    <div id="fpStep3" class="reg-card" style="display:none;">
      <div style="text-align:center;padding:20px 0;">
        <div style="font-size:48px;margin-bottom:16px;">🔐</div>
        <h1>비밀번호 변경 완료!</h1>
        <p class="reg-sub">새 비밀번호로 로그인해주세요.</p>
        <a href="/login" class="btn-full" style="display:inline-block;text-decoration:none;text-align:center;margin-top:24px;">로그인하기</a>
      </div>
    </div>
  </section>
</Base>

<style>
  .reg-page { min-height:100vh; display:flex; align-items:center; justify-content:center; padding:120px 20px 60px; background:var(--color-bg-alt); }
  .reg-card { background:#fff; border-radius:16px; padding:40px; width:100%; max-width:480px; box-shadow:0 4px 24px rgba(0,0,0,0.06); }
  .reg-card h1 { font-size:28px; font-weight:700; margin-bottom:8px; }
  .reg-sub { color:#64748b; font-size:15px; margin-bottom:28px; }
  .field { margin-bottom:16px; }
  .field label { display:block; font-size:13px; font-weight:600; color:#475569; margin-bottom:6px; }
  .field input { width:100%; padding:11px 14px; border:1.5px solid #d1d5db; border-radius:10px; font-size:15px; font-family:inherit; }
  .field input:focus { outline:none; border-color:#2563eb; box-shadow:0 0 0 3px rgba(37,99,235,0.1); }
  .email-input-row { display:flex; align-items:center; border:1.5px solid #d1d5db; border-radius:10px; overflow:hidden; }
  .email-input-row:focus-within { border-color:#2563eb; box-shadow:0 0 0 3px rgba(37,99,235,0.1); }
  .email-input-row input { border:none!important; border-radius:0!important; box-shadow:none!important; flex:1; }
  .email-domain { padding:0 14px; color:#64748b; font-size:14px; font-weight:500; white-space:nowrap; background:#f8fafc; border-left:1px solid #e2e8f0; align-self:stretch; display:flex; align-items:center; }
  .btn-full { width:100%; padding:13px; background:#0f172a; color:#fff; border:none; border-radius:10px; font-size:15px; font-weight:600; cursor:pointer; font-family:inherit; }
  .btn-full:hover { background:#1e293b; }
  .msg { margin-top:12px; font-size:13px; text-align:center; min-height:20px; }
  .msg.error { color:#ef4444; }
  .msg.success { color:#16a34a; }
  .reg-footer { margin-top:20px; text-align:center; }
  .link-back { color:#64748b; text-decoration:none; font-size:14px; background:none; border:none; cursor:pointer; font-family:inherit; }
  .link-back:hover { color:#0f172a; }
</style>

<script>
  let emailFull = '';

  document.getElementById('fpBack')!.addEventListener('click', () => {
    document.getElementById('fpStep2')!.style.display = 'none';
    document.getElementById('fpStep1')!.style.display = 'block';
  });

  // Step 1: 인증 코드 발송
  document.getElementById('fpSendBtn')!.addEventListener('click', async () => {
    const user = (document.getElementById('fpEmailUser') as HTMLInputElement).value.trim();
    const msg = document.getElementById('fpMsg1')!;
    if (!user) { msg.textContent = '이메일을 입력해주세요'; msg.className = 'msg error'; return; }
    emailFull = user + '@acetec-korea.co.kr';
    msg.textContent = '발송 중...'; msg.className = 'msg';

    const res = await fetch('/api/auth/send-code', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ email: emailFull, purpose: 'reset' }),
    });
    const data = await res.json();
    if (res.ok) {
      document.getElementById('fpStep1')!.style.display = 'none';
      document.getElementById('fpStep2')!.style.display = 'block';
    } else {
      msg.textContent = data.error || '발송 실패'; msg.className = 'msg error';
    }
  });

  // Step 2: 비밀번호 변경
  document.getElementById('fpResetBtn')!.addEventListener('click', async () => {
    const code = (document.getElementById('fpCode') as HTMLInputElement).value.trim();
    const pw = (document.getElementById('fpNewPw') as HTMLInputElement).value;
    const pwC = (document.getElementById('fpNewPwConfirm') as HTMLInputElement).value;
    const msg = document.getElementById('fpMsg2')!;
    if (!code || code.length !== 6) { msg.textContent = '6자리 인증 코드를 입력해주세요'; msg.className = 'msg error'; return; }
    if (!pw || pw.length < 6) { msg.textContent = '비밀번호는 6자 이상이어야 합니다'; msg.className = 'msg error'; return; }
    if (pw !== pwC) { msg.textContent = '비밀번호가 일치하지 않습니다'; msg.className = 'msg error'; return; }
    msg.textContent = '처리 중...'; msg.className = 'msg';

    const res = await fetch('/api/auth/reset-password', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ email: emailFull, code, newPassword: pw }),
    });
    const data = await res.json();
    if (res.ok) {
      document.getElementById('fpStep2')!.style.display = 'none';
      document.getElementById('fpStep3')!.style.display = 'block';
    } else {
      msg.textContent = data.error || '변경 실패'; msg.className = 'msg error';
    }
  });
</script>
