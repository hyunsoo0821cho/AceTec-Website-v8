<script>
  // Chapter accordion toggle
  function handleChapterToggle(e: Event) {
    const el = e.target as HTMLElement;
    const head = el.closest('.ch-head');
    if (!head) return;
    e.stopPropagation();

    if (e instanceof KeyboardEvent) {
      if (e.key !== 'Enter' && e.key !== ' ') return;
      e.preventDefault();
    }

    const item = head.parentElement;
    if (!item || !item.classList.contains('ch-item')) return;

    const html = document.documentElement;

    // Disable smooth scroll temporarily (v7 behavior)
    html.classList.add('no-smooth');

    // Close other open items instantly (no transition)
    const allItems = item.parentElement?.querySelectorAll('.ch-item.open');
    allItems?.forEach((sibling) => {
      if (sibling !== item) {
        const body = sibling.querySelector('.ch-body') as HTMLElement;
        if (body) body.style.transition = 'none';
        sibling.classList.remove('open');
        const sibHead = sibling.querySelector('.ch-head');
        sibHead?.setAttribute('aria-expanded', 'false');
      }
    });

    // Force layout reflow
    void document.body.offsetHeight;

    // Calculate target position BEFORE toggling (stable state)
    const targetY = window.pageYOffset + item.getBoundingClientRect().top;

    // Toggle current item (with no transition)
    const currentBody = item.querySelector('.ch-body') as HTMLElement;
    if (currentBody) currentBody.style.transition = 'none';
    item.classList.toggle('open');
    const isOpen = item.classList.contains('open');
    head.setAttribute('aria-expanded', isOpen ? 'true' : 'false');
    void item.offsetHeight; // Force layout

    // Scroll to opened item instantly (v7 behavior)
    if (isOpen) {
      const header = document.querySelector('.header') as HTMLElement;
      const headerH = header ? header.offsetHeight : 0;
      window.scrollTo({ top: targetY - headerH, behavior: 'instant' as ScrollBehavior });
    }

    // Restore transitions after layout settles
    setTimeout(() => {
      document.querySelectorAll('.ch-body').forEach((b) => {
        (b as HTMLElement).style.transition = '';
      });
      html.classList.remove('no-smooth');
    }, 100);
  }

  // FAQ accordion toggle
  function handleFaqToggle(e: Event) {
    const el = e.target as HTMLElement;
    const title = el.closest('.acc-title');
    if (!title) return;

    if (e instanceof KeyboardEvent) {
      if (e.key !== 'Enter' && e.key !== ' ') return;
      e.preventDefault();
    }

    const item = title.parentElement;
    if (!item || !item.classList.contains('acc-item')) return;

    item.classList.toggle('open');
    const isOpen = item.classList.contains('open');
    title.setAttribute('aria-expanded', isOpen ? 'true' : 'false');
  }

  // Bind chapter accordion (capture phase, matching v7)
  document.addEventListener('click', handleChapterToggle, true);
  document.addEventListener('keydown', handleChapterToggle, true);

  // Bind FAQ accordion
  document.querySelectorAll('.acc-title').forEach((title) => {
    title.addEventListener('click', handleFaqToggle);
    title.addEventListener('keydown', handleFaqToggle);
  });
</script>
