---
export const prerender = false;
import Base from '../layouts/Base.astro';
import { verifySession, getSessionIdFromCookie } from '../lib/auth';

const cookie = Astro.request.headers.get('cookie');
const sessionId = verifySession(getSessionIdFromCookie(cookie));
if (!sessionId) return Astro.redirect('/login');
---

<Base title="내 계정 - AceTec">
  <section class="acct-page">
    <div class="acct-container">
      <!-- 프로필 카드 -->
      <div class="acct-card profile-card">
        <div class="avatar-wrap">
          <img id="avatarImg" src="/images/misc/default-avatar.svg" alt="Profile" class="avatar-img" />
          <label class="avatar-edit" for="avatarInput" title="사진 변경">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 20h9"/><path d="M16.5 3.5a2.121 2.121 0 0 1 3 3L7 19l-4 1 1-4L16.5 3.5z"/></svg>
          </label>
          <input type="file" id="avatarInput" accept="image/*" hidden />
        </div>
        <h2 id="profileName">-</h2>
        <p class="profile-role" id="profileRole">-</p>
        <p class="profile-email" id="profileEmail">-</p>
        <button class="btn-logout" id="logoutBtn">로그아웃</button>
      </div>

      <!-- 기본 정보 -->
      <div class="acct-card info-card">
        <div class="card-header">
          <h3>기본 정보</h3>
          <button class="btn-edit-toggle" id="editToggle">수정</button>
        </div>
        <div class="info-grid" id="infoView">
          <div class="info-item">
            <span class="info-label">사용자명</span>
            <span class="info-value" id="infoUsername">-</span>
          </div>
          <div class="info-item">
            <span class="info-label">이름</span>
            <span class="info-value" id="infoDisplayName">-</span>
          </div>
          <div class="info-item">
            <span class="info-label">이메일</span>
            <span class="info-value" id="infoEmail">-</span>
          </div>
          <div class="info-item">
            <span class="info-label">전화번호</span>
            <span class="info-value" id="infoPhone">-</span>
          </div>
          <div class="info-item">
            <span class="info-label">역할</span>
            <span class="info-value" id="infoRole">-</span>
          </div>
          <div class="info-item full">
            <span class="info-label">소개</span>
            <span class="info-value" id="infoBio">-</span>
          </div>
        </div>

        <!-- 수정 폼 -->
        <div class="edit-form" id="editForm" style="display:none;">
          <div class="field">
            <label>이름</label>
            <input type="text" id="editDisplayName" placeholder="이름을 입력하세요" />
          </div>
          <div class="field">
            <label>전화번호</label>
            <input type="tel" id="editPhone" placeholder="010-1234-5678" />
          </div>
          <div class="field">
            <label>소개</label>
            <textarea id="editBio" rows="3" placeholder="간단한 자기소개"></textarea>
          </div>
          <div class="form-actions">
            <button class="btn-cancel" id="editCancel">취소</button>
            <button class="btn-save" id="editSave">저장</button>
          </div>
        </div>
      </div>
    </div>
  </section>
</Base>

<style>
  .acct-page {
    min-height: 100vh;
    padding: 120px 20px 60px;
    background: var(--color-bg-alt, #f8fafc);
  }
  .acct-container {
    max-width: 800px;
    margin: 0 auto;
    display: flex;
    flex-direction: column;
    gap: 24px;
  }
  .acct-card {
    background: #fff;
    border-radius: 16px;
    padding: 32px;
    box-shadow: 0 1px 8px rgba(0,0,0,0.06);
  }

  /* 프로필 카드 */
  .profile-card {
    text-align: center;
  }
  .avatar-wrap {
    position: relative;
    display: inline-block;
    margin-bottom: 16px;
  }
  .avatar-img {
    width: 120px;
    height: 120px;
    border-radius: 50%;
    object-fit: cover;
    border: 4px solid #e2e8f0;
    background: #f1f5f9;
  }
  .avatar-edit {
    position: absolute;
    bottom: 4px;
    right: 4px;
    width: 32px;
    height: 32px;
    border-radius: 50%;
    background: #0f172a;
    color: #fff;
    display: flex;
    align-items: center;
    justify-content: center;
    cursor: pointer;
    transition: background 0.15s;
  }
  .avatar-edit:hover { background: #334155; }
  .profile-card h2 { font-size: 24px; font-weight: 700; margin-bottom: 4px; }
  .profile-role { font-size: 13px; color: #64748b; text-transform: uppercase; font-weight: 600; letter-spacing: 0.04em; }
  .profile-email { font-size: 14px; color: #94a3b8; margin-top: 4px; }
  .btn-logout {
    margin-top: 16px;
    padding: 10px 32px;
    border: 1px solid #ef4444;
    border-radius: 10px;
    background: #fff;
    color: #ef4444;
    font-size: 14px;
    font-weight: 600;
    cursor: pointer;
    font-family: inherit;
    transition: all 0.15s;
  }
  .btn-logout:hover { background: #fef2f2; }

  /* 기본 정보 */
  .card-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 20px;
  }
  .card-header h3 { font-size: 18px; font-weight: 600; }
  .btn-edit-toggle {
    padding: 6px 16px;
    border: 1px solid #d1d5db;
    border-radius: 8px;
    background: #fff;
    font-size: 13px;
    font-weight: 500;
    cursor: pointer;
    font-family: inherit;
    transition: all 0.15s;
  }
  .btn-edit-toggle:hover { background: #f1f5f9; }

  .info-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 16px;
  }
  .info-item { display: flex; flex-direction: column; gap: 4px; }
  .info-item.full { grid-column: 1 / -1; }
  .info-label { font-size: 12px; font-weight: 600; color: #64748b; text-transform: uppercase; letter-spacing: 0.04em; }
  .info-value { font-size: 15px; color: #0f172a; }

  /* 수정 폼 */
  .edit-form { display: flex; flex-direction: column; gap: 16px; }
  .field label { display: block; font-size: 13px; font-weight: 600; color: #475569; margin-bottom: 6px; }
  .field input, .field textarea {
    width: 100%; padding: 10px 14px; border: 1.5px solid #d1d5db; border-radius: 10px; font-size: 14px; font-family: inherit;
  }
  .field input:focus, .field textarea:focus { outline: none; border-color: #2563eb; box-shadow: 0 0 0 3px rgba(37,99,235,0.1); }
  .form-actions { display: flex; gap: 8px; justify-content: flex-end; }
  .btn-cancel {
    padding: 10px 20px; border: 1px solid #d1d5db; border-radius: 10px; background: #fff; cursor: pointer; font-size: 14px; font-family: inherit;
  }
  .btn-save {
    padding: 10px 24px; border: none; border-radius: 10px; background: #0f172a; color: #fff; cursor: pointer; font-size: 14px; font-weight: 600; font-family: inherit;
  }
  .btn-save:hover { background: #1e293b; }
  .btn-cancel:hover { background: #f1f5f9; }

  /* toast */
  .acct-toast {
    position: fixed; bottom: 24px; left: 50%; transform: translateX(-50%); background: #0f172a; color: #fff;
    padding: 12px 24px; border-radius: 10px; font-size: 14px; font-weight: 500; z-index: 9999;
    opacity: 0; transition: opacity 0.3s;
  }
  .acct-toast.show { opacity: 1; }

  @media (max-width: 600px) {
    .info-grid { grid-template-columns: 1fr; }
    .acct-card { padding: 24px 20px; }
  }
</style>

<script>
  let userData: any = null;

  function toast(msg: string) {
    let t = document.querySelector('.acct-toast') as HTMLElement;
    if (!t) { t = document.createElement('div'); t.className = 'acct-toast'; document.body.appendChild(t); }
    t.textContent = msg;
    t.classList.add('show');
    setTimeout(() => t.classList.remove('show'), 2500);
  }

  async function loadProfile() {
    const res = await fetch('/api/auth/me');
    if (!res.ok) { window.location.href = '/login'; return; }
    userData = await res.json();

    // 프로필 카드
    document.getElementById('profileName')!.textContent = userData.displayName || userData.username;
    document.getElementById('profileRole')!.textContent = userData.role || '-';
    document.getElementById('profileEmail')!.textContent = userData.email || '-';
    if (userData.avatarUrl) {
      (document.getElementById('avatarImg') as HTMLImageElement).src = userData.avatarUrl;
    }

    // 기본 정보
    document.getElementById('infoUsername')!.textContent = userData.username;
    document.getElementById('infoDisplayName')!.textContent = userData.displayName || '-';
    document.getElementById('infoEmail')!.textContent = userData.email || '-';
    document.getElementById('infoPhone')!.textContent = userData.phone || '-';
    document.getElementById('infoRole')!.textContent = userData.role || '-';
    document.getElementById('infoBio')!.textContent = userData.bio || '-';
  }

  // 수정 토글
  const editToggle = document.getElementById('editToggle')!;
  const infoView = document.getElementById('infoView')!;
  const editForm = document.getElementById('editForm')!;

  editToggle.addEventListener('click', () => {
    if (editForm.style.display === 'none') {
      // 수정 모드
      (document.getElementById('editDisplayName') as HTMLInputElement).value = userData?.displayName || '';
      (document.getElementById('editPhone') as HTMLInputElement).value = userData?.phone || '';
      (document.getElementById('editBio') as HTMLTextAreaElement).value = userData?.bio || '';
      infoView.style.display = 'none';
      editForm.style.display = 'flex';
      editToggle.textContent = '취소';
    } else {
      infoView.style.display = 'grid';
      editForm.style.display = 'none';
      editToggle.textContent = '수정';
    }
  });

  document.getElementById('editCancel')!.addEventListener('click', () => {
    infoView.style.display = 'grid';
    editForm.style.display = 'none';
    editToggle.textContent = '수정';
  });

  // 저장
  document.getElementById('editSave')!.addEventListener('click', async () => {
    const displayName = (document.getElementById('editDisplayName') as HTMLInputElement).value;
    const phone = (document.getElementById('editPhone') as HTMLInputElement).value;
    const bio = (document.getElementById('editBio') as HTMLTextAreaElement).value;

    const res = await fetch('/api/auth/me', {
      method: 'PUT',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ displayName, phone, bio }),
    });
    if (res.ok) {
      toast('프로필이 저장되었습니다');
      infoView.style.display = 'grid';
      editForm.style.display = 'none';
      editToggle.textContent = '수정';
      loadProfile();
    } else {
      toast('저장에 실패했습니다');
    }
  });

  // 아바타 업로드
  document.getElementById('avatarInput')!.addEventListener('change', async (e) => {
    const file = (e.target as HTMLInputElement).files?.[0];
    if (!file) return;
    const form = new FormData();
    form.append('avatar', file);
    const res = await fetch('/api/auth/avatar', { method: 'POST', body: form });
    const data = await res.json();
    if (res.ok && data.avatarUrl) {
      (document.getElementById('avatarImg') as HTMLImageElement).src = data.avatarUrl;
      toast('프로필 사진이 변경되었습니다');
    } else {
      toast(data.error || '업로드 실패');
    }
  });

  // 로그아웃
  document.getElementById('logoutBtn')!.addEventListener('click', async () => {
    await fetch('/api/auth/logout', { method: 'POST' });
    window.location.href = '/';
  });

  loadProfile();
</script>
