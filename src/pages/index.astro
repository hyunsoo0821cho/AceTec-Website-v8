  .ns-btn-cancel { background: #f3f4f6; color: #374151; }
  .ns-btn-cancel:hover { background: #e5e7eb; }
  .ns-btn-create { background: #2563eb; color: #fff; }
  .ns-btn-create:hover { background: #1d4ed8; }
  .ns-btn:disabled { opacity: 0.5; cursor: not-allowed; }
  .ns-status { font-size: 13px; margin-top: 8px; text-align: center; }
</style>

<script>
  // 새 솔루션 생성 모달
  const addBtn = document.getElementById('addSolutionBtn');
  const nsOverlay = document.getElementById('newSolutionOverlay');
  const nsCancel = document.getElementById('nsCancel');
  const nsCreate = document.getElementById('nsCreate');
  const nsStatus = document.getElementById('nsStatus');

  if (addBtn && nsOverlay) {
    addBtn.addEventListener('click', () => { nsOverlay.classList.add('active'); });
    nsCancel?.addEventListener('click', () => { nsOverlay.classList.remove('active'); });
    nsOverlay.addEventListener('click', (ev) => { if (ev.target === nsOverlay) nsOverlay.classList.remove('active'); });

    nsCreate?.addEventListener('click', async () => {
      const title = (document.getElementById('nsTitle') as HTMLInputElement).value.trim();
      const subtitle = (document.getElementById('nsSubtitle') as HTMLInputElement).value.trim();
      const desc = (document.getElementById('nsDesc') as HTMLTextAreaElement).value.trim();
      if (!title) { if (nsStatus) { nsStatus.textContent = '제목을 입력해주세요.'; nsStatus.style.color = '#ef4444'; } return; }

      nsCreate.setAttribute('disabled', '');
      if (nsStatus) { nsStatus.textContent = '생성 중...'; nsStatus.style.color = '#2563eb'; }

      try {
        const res = await fetch('/api/admin/create-solution', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ title, subtitle, description: desc }),
        });
        const data = await res.json();
        if (data.ok) {
          if (nsStatus) { nsStatus.textContent = '생성 완료! 페이지 이동 중...'; nsStatus.style.color = '#16a34a'; }
          window.location.href = data.href;
        } else {
          if (nsStatus) { nsStatus.textContent = data.error || '생성 실패'; nsStatus.style.color = '#ef4444'; }
          nsCreate.removeAttribute('disabled');
        }
      } catch {
        if (nsStatus) { nsStatus.textContent = '서버 연결 실패'; nsStatus.style.color = '#ef4444'; }
        nsCreate.removeAttribute('disabled');
      }
    });
  }
</script>

<script>
  // Accordion toggle for home page
  function toggleAccordion(e: Event) {
    const el = e.target as HTMLElement;
    // Admin 인라인 편집 중이면 무시 (스페이스바 등 입력 허용)
    if (el.isContentEditable || el.closest('[contenteditable="true"]')) return;
    if (e instanceof KeyboardEvent && e.key !== 'Enter' && e.key !== ' ') return;

    const title = el.closest('.acc-title');
    if (!title) return;
    if (e instanceof KeyboardEvent) e.preventDefault();

    const item = title.parentElement;
    if (!item) return;
    item.classList.toggle('open');
    const isOpen = item.classList.contains('open');
    title.setAttribute('aria-expanded', isOpen ? 'true' : 'false');
  }

  document.addEventListener('click', toggleAccordion);
  document.addEventListener('keydown', toggleAccordion);
</script>
