---
import Base from '../../layouts/Base.astro';
---

<Base title="Sensor Modeling & Simulation Products - AceTec">
  <section class="section pt-page">
    <div class="container">
      <h1 class="heading-page">Sensor Modeling &amp; Simulation</h1>
      <p class="heading-sub color-muted">High-fidelity EO/IR/RF sensor simulation from OKTAL-SE for Hardware-In-the-Loop, Man-In-the-Loop, and training environments across defense and aerospace programs.</p>
      <div class="products-grid">
        <div class="p-card"><div class="p-img"></div><div class="p-name">SE-Workbench-EO</div><div class="p-price">Real-time electro-optical &amp; infrared scene generation for HWIL testing</div></div>
        <div class="p-card"><div class="p-img"></div><div class="p-name">SE-Workbench-RF</div><div class="p-price">RF sensor simulation for radar &amp; electronic warfare environments</div></div>
        <div class="p-card"><div class="p-img"></div><div class="p-name">SE-RAY-SAR</div><div class="p-price">Synthetic aperture radar image simulation &amp; analysis</div></div>
        <div class="p-card"><div class="p-img"></div><div class="p-name">SE-FAST-HWIL</div><div class="p-price">High-speed Hardware-In-the-Loop simulation engine</div></div>
        <div class="p-card"><div class="p-img"></div><div class="p-name">Active EO &amp; GNSS Simulation</div><div class="p-price">Active electro-optical sensor &amp; GNSS signal simulation</div></div>
        <div class="p-card"><div class="p-img"></div><div class="p-name">3D Terrain &amp; Scene Database</div><div class="p-price">Real-time 3D terrain generation · Building models · Special effects · APIs</div></div>
      </div>
      <div class="mt-xl"><a href="/solutions" class="btn-secondary">&larr; BACK TO ALL SOLUTIONS</a></div>
    </div>
  </section>
</Base>

<style>
  .products-grid { display: grid; grid-template-columns: repeat(4, minmax(0, 1fr)); gap: var(--spacing-lg); align-items: start; }
  .p-card { position: relative; cursor: pointer; transition: transform var(--transition-slow); }
  .p-img { position: relative; overflow: hidden; background: var(--color-gray-200); padding-bottom: 75%; }
  .p-img img { position: absolute; top: 0; left: 0; width: 100%; height: 100%; object-fit: cover; transition: opacity var(--transition-slow); }
  @media (hover: hover) { .p-card:hover { transform: translateY(-4px); } .p-card:hover img { opacity: 0.85; } }
  .p-card:active { transform: translateY(0) scale(0.98); transition: all var(--transition-fast); }
  .p-card .p-name { font-size: var(--font-size-lg); margin-top: 12px; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }
  .p-card .p-price { font-size: var(--font-size-md); margin-top: var(--spacing-xs); overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }
  @media (max-width: 1024px) { .products-grid { grid-template-columns: repeat(2, minmax(0, 1fr)); } }
  @media (max-width: 768px) {
    .products-grid { gap: var(--spacing-md); }
    .p-card .p-name { font-size: 13px; white-space: normal; line-height: 1.3; }
    .p-card .p-price { font-size: 11px; white-space: normal; line-height: 1.3; }
  }
</style>
