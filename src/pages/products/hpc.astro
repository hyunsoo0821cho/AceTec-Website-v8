---
import Base from '../../layouts/Base.astro';
---

<Base title="High Performance Computing Products - AceTec">
  <section class="section pt-page">
    <div class="container">
      <h1 class="heading-page">High Performance Computing</h1>
      <p class="heading-sub color-muted">High-density GPU servers and PCIe expansion systems for machine learning, financial analysis, military applications, medical imaging, and scientific research.</p>
      <div class="products-grid">
        <div class="p-card"><div class="p-img"><img src="/images/products/hpc-servers.png" alt="HPC Servers" loading="lazy"></div><div class="p-name">GPU Servers</div><div class="p-price">High-density multi-GPU computing platforms for AI &amp; deep learning</div></div>
        <div class="p-card"><div class="p-img"><img src="/images/products/hpc-servers.png" alt="HPC Desktop" loading="lazy"></div><div class="p-name">GPU Desktop &amp; Appliances</div><div class="p-price">Workstation-class GPU platforms for development &amp; inference</div></div>
        <div class="p-card"><div class="p-img"></div><div class="p-name">PCIe Expansion — One Stop Systems</div><div class="p-price">GPU expansion chassis · PCIe switching · High-performance NVMe storage</div></div>
        <div class="p-card"><div class="p-img"></div><div class="p-name">Video Acceleration Platform</div><div class="p-price">Hardware-accelerated video encoding, decoding &amp; transcoding</div></div>
      </div>
      <div class="mt-xl"><a href="/solutions" class="btn-secondary">&larr; BACK TO ALL SOLUTIONS</a></div>
    </div>
  </section>
</Base>

<style>
  .products-grid { display: grid; grid-template-columns: repeat(4, minmax(0, 1fr)); gap: var(--spacing-lg); align-items: start; }
  .p-card { position: relative; cursor: pointer; transition: transform var(--transition-slow); }
  .p-img { position: relative; overflow: hidden; background: var(--color-gray-200); padding-bottom: 75%; }
  .p-img img { position: absolute; top: 0; left: 0; width: 100%; height: 100%; object-fit: cover; transition: opacity var(--transition-slow); }
  @media (hover: hover) { .p-card:hover { transform: translateY(-4px); } .p-card:hover img { opacity: 0.85; } }
  .p-card:active { transform: translateY(0) scale(0.98); transition: all var(--transition-fast); }
  .p-card .p-name { font-size: var(--font-size-lg); margin-top: 12px; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }
  .p-card .p-price { font-size: var(--font-size-md); margin-top: var(--spacing-xs); overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }
  @media (max-width: 1024px) { .products-grid { grid-template-columns: repeat(2, minmax(0, 1fr)); } }
  @media (max-width: 768px) {
    .products-grid { gap: var(--spacing-md); }
    .p-card .p-name { font-size: 13px; white-space: normal; line-height: 1.3; }
    .p-card .p-price { font-size: 11px; white-space: normal; line-height: 1.3; }
  }
</style>
