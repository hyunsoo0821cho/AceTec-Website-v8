---
export const prerender = false;

import Base from '../../layouts/Base.astro';
import ProductGrid from '../../components/ProductGrid.astro';
import AdminInline from '../../components/AdminInline.astro';
import { verifySession, getSessionIdFromCookie } from '../../lib/auth';
import fs from 'fs';
import path from 'path';
const cookie = Astro.request.headers.get('cookie');
const isAdmin = !!verifySession(getSessionIdFromCookie(cookie));

const root = process.cwd();
const category = Astro.params.category ?? '';
const filePath = path.join(root, 'src', 'content', 'products', `${category}.json`);

if (!fs.existsSync(filePath)) {
  return Astro.redirect('/solutions');
}

const product = JSON.parse(fs.readFileSync(filePath, 'utf-8'));
function e(p: string) {
  return isAdmin ? { 'data-edit': p } : {};
}
---

<Base title={product.pageTitle}>
  <AdminInline page={`products-${category}`} isAdmin={isAdmin} />
  <section class="section pt-page">
    <div class="container">
      <h1 class="heading-page" {...e('title')} data-i18n={`productDetail.${category}Title`}>{product.title}</h1>
      <p class="heading-sub color-muted" {...e('description')} data-i18n={`productDetail.${category}Desc`}>{product.description}</p>
      <ProductGrid items={product.items} sections={product.sections} isAdmin={isAdmin} category={category} />
      <div class="mt-xl"><a href="/" class="btn-secondary" data-i18n="products.backToHome">&larr; 홈페이지로 돌아가기</a></div>
    </div>
  </section>
</Base>
<script>
  // URL 해시로 접근 시 해당 섹션으로 스크롤
  if (window.location.hash) {
    setTimeout(() => {
      const el = document.querySelector(window.location.hash);
      if (el) el.scrollIntoView({ behavior: 'smooth', block: 'start' });
    }, 300);
  }
</script>
