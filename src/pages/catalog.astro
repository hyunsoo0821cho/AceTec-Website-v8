---
export const prerender = false;

import Base from '../layouts/Base.astro';
import AdminInline from '../components/AdminInline.astro';
import { verifySession, getSessionIdFromCookie, getUserInfo, hasDetailAccess } from '../lib/auth';
import fs from 'fs';
import path from 'path';

const cookie = Astro.request.headers.get('cookie');
const sessionId = verifySession(getSessionIdFromCookie(cookie));
const userInfo = sessionId ? getUserInfo(sessionId) : null;
const userRole = userInfo?.role || '';
const isAdmin = userRole === 'admin';
const canViewDetails = sessionId ? hasDetailAccess(sessionId) : false;
const hideDetails = !isAdmin && !canViewDetails;

const root = process.cwd();
const catalog = JSON.parse(
  fs.readFileSync(path.join(root, 'src', 'content', 'pages', 'catalog.json'), 'utf-8')
);

function e(p: string) {
  return isAdmin ? { 'data-edit': p } : {};
}
function img(p: string, preset: string) {
  return isAdmin ? { 'data-img': p, 'data-preset': preset } : {};
}

const totalProducts = catalog.categories.reduce((sum: number, cat: any) => sum + cat.products.length, 0);
---

<Base title="Product Catalog - AceTec">
  <AdminInline page="catalog" isAdmin={isAdmin} />

  <section class="section pt-page">
    <div class="container">
      <h1 class="heading-page" data-i18n="catalog.title">{catalog.title}</h1>
      <p class="heading-sub color-muted" data-i18n="catalog.desc">{catalog.description}</p>

      <!-- 카테고리 통계 -->

      <!-- 카테고리 목차 -->
      <div class="cat-toc">
        <strong>Categories: </strong>
        {catalog.categories.map((cat: any) => (
          <a href={`#${cat.id}`} class="cat-toc-link">{cat.title}</a>
        ))}
      </div>

      {/* Admin: 카테고리 추가 버튼 */}
      {isAdmin && (
        <button
          class="admin-add-btn"
          data-admin-add="categories"
          data-admin-template='{"id":"cs-new","icon":"📁","title":"New Category","products":[]}'
          style="margin:16px 0;"
        >
          + Add Category
        </button>
      )}

      <!-- 카테고리 & 제품 목록 -->
      {catalog.categories.map((cat: any, ci: number) => (
        <div class="cat-group" style="position:relative;">
          {isAdmin && (
            <button class="admin-delete-btn" data-admin-delete={`categories[${ci}]`} title="Delete Category">
              &times;
            </button>
          )}
          <h2 class="cat-section-title" id={cat.id}>
            <span {...e(`categories[${ci}].icon`)}>{cat.icon}</span>{' '}
            <span {...e(`categories[${ci}].title`)}>{cat.title}</span>
          </h2>

          <div class="products-grid">
            {cat.products.map((prod: any, pi: number) => (
              <div class="p-card" style="position:relative;">
                {isAdmin && (
                  <button class="admin-delete-btn" data-admin-delete={`categories[${ci}].products[${pi}]`} title="Delete Product">
                    &times;
                  </button>
                )}
                <div class="p-img lb-trigger">
                  <img
                    src={prod.image}
                    alt={prod.name}
                    loading="lazy"
                    {...img(`categories[${ci}].products[${pi}].image`, 'product')}
                  />
                </div>
                <div class="p-name" {...e(`categories[${ci}].products[${pi}].name`)}>{prod.name}</div>
                {hideDetails ? (
                  <div class="p-locked">
                    <span class="p-locked-icon">🔒</span>
                    <span class="p-locked-text">상세 설명은 승인된 사용자만 볼 수 있습니다</span>
                  </div>
                ) : prod.features.length > 0 && (
                  <ul class="p-features" {...e(`categories[${ci}].products[${pi}].featuresHtml`)}>
                    {prod.features.map((f: string) => <li>{f}</li>)}
                  </ul>
                )}
              </div>
            ))}
          </div>

          {/* Admin: 제품 추가 버튼 */}
          {isAdmin && (
            <button
              class="admin-add-btn"
              data-admin-add={`categories[${ci}].products`}
              data-admin-template='{"name":"New Product","image":"","features":["Feature 1"]}'
              style="margin-top:12px;"
            >
              + Add Product
            </button>
          )}
        </div>
      ))}

    </div>

    {!isAdmin && !canViewDetails && userRole && (
      <div class="access-request-banner">
        <p>제품 상세 설명을 보려면 열람 권한이 필요합니다.</p>
        <button class="btn-request-access" id="requestAccessBtn">설명 보기 요청</button>
      </div>
    )}
    {!isAdmin && !canViewDetails && !userRole && (
      <div class="access-request-banner">
        <p>제품 상세 설명을 보려면 로그인이 필요합니다.</p>
        <a href="/login" class="btn-request-access" style="text-decoration:none;display:inline-block;">로그인</a>
      </div>
    )}
  </section>
</Base>

<style>
  .cat-stats {
    display: flex;
    flex-wrap: wrap;
    gap: 10px;
    margin: 16px 0 24px;
  }
  .cat-stat {
    background: var(--color-gray-100);
    border: 1px solid var(--color-gray-300);
    padding: 8px 14px;
    border-radius: 6px;
    text-align: center;
  }
  .cat-stat b {
    display: block;
    font-size: 20px;
    color: var(--color-black);
  }
  .cat-stat span {
    font-size: 11px;
    color: var(--color-gray-600);
  }
  .cat-toc {
    background: var(--color-gray-100);
    border: 1px solid var(--color-gray-300);
    border-radius: 8px;
    padding: 16px 20px;
    margin: 20px 0;
    display: flex;
    flex-wrap: wrap;
    gap: 8px 18px;
    align-items: center;
    font-size: 16px;
  }
  .cat-toc-link {
    color: var(--color-black);
    text-decoration: none;
    font-size: 16px;
    font-weight: 500;
  }
  .cat-toc-link:hover {
    text-decoration: underline;
  }
  .cat-group {
    margin-bottom: 32px;
  }
  .cat-section-title {
    font-size: 20px;
    margin: 40px 0 16px;
    padding: 10px 16px;
    background: var(--color-gray-200);
    border-left: 4px solid var(--color-black);
    border-radius: 4px;
    font-weight: 700;
  }
  .products-grid {
    display: grid;
    grid-template-columns: repeat(4, minmax(0, 1fr));
    gap: var(--spacing-lg);
    align-items: start;
  }
  .p-card {
    position: relative;
    cursor: default;
    transition: transform var(--transition-slow);
  }
  .p-img {
    position: relative;
    overflow: hidden;
    background: var(--color-gray-200);
    padding-bottom: 75%;
  }
  .p-img img {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: opacity var(--transition-slow);
  }
  .p-card .p-name {
    font-size: var(--font-size-lg);
    margin-top: 12px;
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
    font-weight: 600;
  }
  .p-features {
    margin-top: 8px;
    padding: 0 0 0 16px;
    font-size: 11px;
    line-height: 1.6;
    color: #555;
    list-style: none;
  }
  .p-features li {
    position: relative;
    padding-left: 10px;
  }
  .p-features li::before {
    content: "·";
    position: absolute;
    left: 0;
    color: #999;
    font-weight: 700;
  }
  @media (hover: hover) {
    .p-card:hover { transform: translateY(-4px); }
    .p-card:hover img { opacity: 0.85; }
  }
  @media (max-width: 1024px) {
    .products-grid { grid-template-columns: repeat(2, minmax(0, 1fr)); }
  }
  /* 잠금 표시 */
  .p-locked {
    margin-top: 8px;
    padding: 8px 10px;
    background: #f8fafc;
    border: 1px dashed #cbd5e1;
    border-radius: 6px;
    text-align: center;
    font-size: 11px;
    color: #94a3b8;
  }
  .p-locked-icon { font-size: 14px; }
  .p-locked-text { display: block; margin-top: 2px; }

  /* 요청 배너 */
  .access-request-banner {
    margin-top: 40px;
    padding: 24px;
    background: #eff6ff;
    border: 1px solid #bfdbfe;
    border-radius: 12px;
    text-align: center;
  }
  .access-request-banner p {
    font-size: 15px;
    color: #1e40af;
    margin-bottom: 12px;
  }
  .btn-request-access {
    padding: 10px 28px;
    background: #2563eb;
    color: #fff;
    border: none;
    border-radius: 8px;
    font-size: 14px;
    font-weight: 600;
    cursor: pointer;
    transition: background 0.15s;
  }
  .btn-request-access:hover { background: #1d4ed8; }
  .btn-request-access:disabled { background: #94a3b8; cursor: not-allowed; }

  @media (max-width: 768px) {
    .products-grid { grid-template-columns: 1fr; }
    .cat-toc { gap: 4px 10px; }
  }
</style>

<script>
  // TOC smooth scroll
  document.querySelectorAll('.cat-toc-link').forEach(link => {
    link.addEventListener('click', (ev) => {
      ev.preventDefault();
      const target = document.getElementById(link.getAttribute('href')?.replace('#', '') || '');
      if (target) target.scrollIntoView({ behavior: 'smooth' });
    });
  });

  // 설명 보기 요청 버튼
  const reqBtn = document.getElementById('requestAccessBtn');
  if (reqBtn) {
    reqBtn.addEventListener('click', async () => {
      reqBtn.setAttribute('disabled', '');
      reqBtn.textContent = '요청 중...';
      try {
        const res = await fetch('/api/access-request', { method: 'POST' });
        const data = await res.json();
        if (data.ok) {
          reqBtn.textContent = '요청 완료 — 관리자 승인 대기 중';
        } else {
          reqBtn.textContent = data.error || '요청 실패';
          setTimeout(() => { reqBtn.removeAttribute('disabled'); reqBtn.textContent = '설명 보기 요청'; }, 3000);
        }
      } catch {
        reqBtn.textContent = '서버 연결 실패';
        setTimeout(() => { reqBtn.removeAttribute('disabled'); reqBtn.textContent = '설명 보기 요청'; }, 3000);
      }
    });
  }
</script>
