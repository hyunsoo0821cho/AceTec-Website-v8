---
export const prerender = false;

import Base from '../layouts/Base.astro';
import AdminInline from '../components/AdminInline.astro';
import { verifySession, getSessionIdFromCookie, getUserInfo, hasDetailAccess } from '../lib/auth';
import fs from 'fs';
import path from 'path';

const cookie = Astro.request.headers.get('cookie');
const sessionId = verifySession(getSessionIdFromCookie(cookie));
const userInfo = sessionId ? getUserInfo(sessionId) : null;
const userRole = userInfo?.role || '';
const isAdmin = userRole === 'admin';
const canViewDetails = sessionId ? hasDetailAccess(sessionId, 'catalog') : false;
const hideDetails = !isAdmin && !canViewDetails;

const root = process.cwd();
const catalog = JSON.parse(
  fs.readFileSync(path.join(root, 'src', 'content', 'pages', 'catalog.json'), 'utf-8')
);

function e(p: string) {
  return isAdmin ? { 'data-edit': p } : {};
}
function img(p: string, preset: string) {
  return isAdmin ? { 'data-img': p, 'data-preset': preset } : {};
}

const totalProducts = catalog.categories.reduce((sum: number, cat: any) => sum + cat.products.length, 0);
---

<Base title="Product Catalog - AceTec">
  <AdminInline page="catalog" isAdmin={isAdmin} />

  <section class="section pt-page">
    <div class="container">
      <h1 class="heading-page" data-i18n="catalog.title">{catalog.title}</h1>
      <p class="heading-sub color-muted" data-i18n="catalog.desc">{catalog.description}</p>

      {!isAdmin && !canViewDetails && userRole && (
        <div class="access-request-banner access-request-banner--top">
          <div class="arb-inner">
            <div class="arb-icon">
              <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="11" width="18" height="11" rx="2" ry="2"/><path d="M7 11V7a5 5 0 0 1 10 0v4"/></svg>
            </div>
            <div class="arb-text">
              <strong>제품 상세 설명을 보려면 열람 권한이 필요합니다.</strong>
              <span>관리자 승인 후 제품 사양, 기술 스펙을 열람할 수 있습니다.</span>
            </div>
            <button class="btn-request-access" id="requestAccessBtnTop">설명 보기 요청</button>
          </div>
        </div>
      )}
      {!isAdmin && !canViewDetails && !userRole && (
        <div class="access-request-banner access-request-banner--top">
          <div class="arb-inner">
            <div class="arb-icon">
              <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="11" width="18" height="11" rx="2" ry="2"/><path d="M7 11V7a5 5 0 0 1 10 0v4"/></svg>
            </div>
            <div class="arb-text">
              <strong>You must log in to view detailed product descriptions.</strong>
              <span>회원가입 후 로그인하여 열람 권한을 요청하실 수 있습니다.</span>
            </div>
            <a href="/register" class="btn-request-access">세부 사항 열람 권한 요청</a>
          </div>
        </div>
      )}

      <!-- 카테고리 목차 -->
      <div class="cat-toc">
        <strong>Categories: </strong>
        {catalog.categories.map((cat: any) => (
          <a href={`#${cat.id}`} class="cat-toc-link" translate="no">{cat.title}</a>
        ))}
      </div>

      {/* Admin: 카테고리 추가 버튼 */}
      {isAdmin && (
        <button
          class="admin-add-btn"
          data-admin-add="categories"
          data-admin-template='{"id":"cs-new","icon":"📁","title":"New Category","products":[]}'
          style="margin:16px 0;"
        >
          + Add Category
        </button>
      )}

      <!-- 카테고리 & 제품 목록 -->
      {catalog.categories.map((cat: any, ci: number) => (
        <div class="cat-group" style="position:relative;">
          {isAdmin && (
            <button class="admin-delete-btn" data-admin-delete={`categories[${ci}]`} title="Delete Category">
              &times;
            </button>
          )}
          <h2 class="cat-section-title" id={cat.id} translate="no">
            <span {...e(`categories[${ci}].icon`)}>{cat.icon}</span>{' '}
            <span {...e(`categories[${ci}].title`)}>{cat.title}</span>
          </h2>

          <div class="products-grid">
            {cat.products.map((prod: any, pi: number) => (
              <div class="p-card" style="position:relative;">
                {isAdmin && (
                  <button class="admin-delete-btn" data-admin-delete={`categories[${ci}].products[${pi}]`} title="Delete Product">
                    &times;
                  </button>
                )}
                <div class="p-img lb-trigger">
                  <img
                    src={prod.image}
                    alt={prod.name}
                    loading="lazy"
                    {...img(`categories[${ci}].products[${pi}].image`, 'product')}
                  />
                </div>
                <div class="p-name" translate="no" {...e(`categories[${ci}].products[${pi}].name`)}>{prod.name}</div>
                {hideDetails ? (
                  <div class="p-locked">
                    <span class="p-locked-icon">🔒</span>
                    <span class="p-locked-text">상세 설명은 승인된 사용자만 볼 수 있습니다</span>
                  </div>
                ) : prod.features.length > 0 && (
                  <ul class="p-features" {...e(`categories[${ci}].products[${pi}].featuresHtml`)}>
                    {prod.features.map((f: string) => <li>{f}</li>)}
                  </ul>
                )}
              </div>
            ))}
          </div>

          {/* Admin: 제품 추가 버튼 */}
          {isAdmin && (
            <button
              class="admin-add-btn"
              data-admin-add={`categories[${ci}].products`}
              data-admin-template='{"name":"New Product","image":"","features":["Feature 1"]}'
              style="margin-top:12px;"
            >
              + Add Product
            </button>
          )}
        </div>
      ))}

    </div>
  </section>

  <!-- 확대 모달 오버레이 -->
  <div class="p-detail-overlay" id="detailOverlay">
    <div class="p-detail-modal">
      <button class="p-detail-modal-close" id="detailModalClose">&times;</button>
      <div class="p-detail-modal-title" id="detailModalTitle"></div>
      <ul class="p-detail-modal-list" id="detailModalList"></ul>
    </div>
  </div>
</Base>

<style>
  .cat-stats {
    display: flex;
    flex-wrap: wrap;
    gap: 10px;
    margin: 16px 0 24px;
  }
  .cat-stat {
    background: var(--color-gray-100);
    border: 1px solid var(--color-gray-300);
    padding: 8px 14px;
    border-radius: 6px;
    text-align: center;
  }
  .cat-stat b {
    display: block;
    font-size: 20px;
    color: var(--color-black);
  }
  .cat-stat span {
    font-size: 11px;
    color: var(--color-gray-600);
  }
  .cat-toc {
    background: var(--color-gray-100);
    border: 1px solid var(--color-gray-300);
    border-radius: 8px;
    padding: 16px 20px;
    margin: 20px 0;
    display: flex;
    flex-wrap: wrap;
    gap: 8px 18px;
    align-items: center;
    font-size: 16px;
  }
  .cat-toc-link {
    color: var(--color-black);
    text-decoration: none;
    font-size: 16px;
    font-weight: 500;
  }
  .cat-toc-link:hover {
    text-decoration: underline;
  }
  .cat-group {
    margin-bottom: 32px;
  }
  .cat-section-title {
    font-size: 20px;
    margin: 40px 0 16px;
    padding: 10px 16px;
    background: var(--color-gray-200);
    border-left: 4px solid var(--color-black);
    border-radius: 4px;
    font-weight: 700;
  }
  .products-grid {
    display: grid;
    grid-template-columns: repeat(4, minmax(0, 1fr));
    gap: var(--spacing-lg);
    align-items: start;
  }
  .p-card {
    position: relative;
    cursor: default;
    transition: transform var(--transition-slow);
  }
  .p-img {
    position: relative;
    overflow: hidden;
    background: var(--color-gray-200);
    padding-bottom: 75%;
  }
  .p-img img {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: opacity var(--transition-slow);
  }
  .p-card .p-name {
    font-size: var(--font-size-xl);
    margin-top: 12px;
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
    font-weight: 600;
  }
  .p-features {
    margin-top: 8px;
    padding: 0 0 0 16px;
    font-size: 14px;
    line-height: 1.7;
    color: #444;
    list-style: none;
    cursor: pointer;
    border-radius: 6px;
    transition: background 0.15s;
  }
  .p-features:hover {
    background: #f1f5f9;
  }
  .p-features li {
    position: relative;
    padding-left: 12px;
    padding-top: 2px;
    padding-bottom: 2px;
  }
  .p-features li::before {
    content: "·";
    position: absolute;
    left: 0;
    color: #999;
    font-weight: 700;
  }

  /* 설명 확대 모달 오버레이 */
  .p-detail-overlay {
    display: none;
    position: fixed;
    top: 0;
    left: 0;
    width: 100vw;
    height: 100vh;
    background: rgba(0,0,0,0.5);
    z-index: 9999;
    justify-content: center;
    align-items: center;
    backdrop-filter: blur(2px);
  }
  .p-detail-overlay.active {
    display: flex;
  }
  .p-detail-modal {
    background: #fff;
    border-radius: 12px;
    padding: 32px 36px;
    max-width: 640px;
    width: 90%;
    max-height: 80vh;
    overflow-y: auto;
    box-shadow: 0 20px 60px rgba(0,0,0,0.25);
    animation: modalIn 0.25s ease-out;
    position: relative;
  }
  .p-detail-modal-title {
    font-size: var(--font-size-2xl);
    font-weight: 700;
    margin-bottom: 16px;
    padding-bottom: 12px;
    border-bottom: 2px solid #e2e8f0;
    color: #1e293b;
  }
  .p-detail-modal-list {
    list-style: none;
    padding: 0;
    margin: 0;
    font-size: 16px;
    line-height: 1.8;
    color: #334155;
  }
  .p-detail-modal-list li {
    position: relative;
    padding: 6px 0 6px 18px;
    border-bottom: 1px solid #f1f5f9;
  }
  .p-detail-modal-list li:last-child {
    border-bottom: none;
  }
  .p-detail-modal-list li::before {
    content: "•";
    position: absolute;
    left: 0;
    color: #2563eb;
    font-weight: 700;
    font-size: 18px;
  }
  .p-detail-modal-close {
    position: absolute;
    top: 12px;
    right: 16px;
    background: none;
    border: none;
    font-size: 24px;
    color: #94a3b8;
    cursor: pointer;
    padding: 4px 8px;
    border-radius: 6px;
    transition: all 0.15s;
  }
  .p-detail-modal-close:hover {
    background: #f1f5f9;
    color: #334155;
  }
  @keyframes modalIn {
    from { opacity: 0; transform: scale(0.95) translateY(10px); }
    to { opacity: 1; transform: scale(1) translateY(0); }
  }
  @media (hover: hover) {
    .p-card:hover { transform: translateY(-4px); }
    .p-card:hover img { opacity: 0.85; }
  }
  @media (max-width: 1024px) {
    .products-grid { grid-template-columns: repeat(2, minmax(0, 1fr)); }
  }
  /* 잠금 표시 */
  .p-locked {
    margin-top: 8px;
    padding: 8px 10px;
    background: #f8fafc;
    border: 1px dashed #cbd5e1;
    border-radius: 6px;
    text-align: center;
    font-size: 11px;
    color: #94a3b8;
  }
  .p-locked-icon { font-size: 14px; }
  .p-locked-text { display: block; margin-top: 2px; }

  /* 요청 배너 */
  .access-request-banner {
    margin: 24px 0 32px;
    padding: 0;
    background: linear-gradient(135deg, #eff6ff 0%, #e0ecff 100%);
    border: 1px solid #bfdbfe;
    border-radius: 14px;
    overflow: hidden;
    box-shadow: 0 2px 12px rgba(37, 99, 235, 0.08);
  }
  .arb-inner {
    display: flex;
    align-items: center;
    gap: 16px;
    padding: 18px 24px;
  }
  .arb-icon {
    flex-shrink: 0;
    width: 44px;
    height: 44px;
    display: flex;
    align-items: center;
    justify-content: center;
    background: rgba(37, 99, 235, 0.1);
    border-radius: 10px;
    color: #2563eb;
  }
  .arb-text {
    flex: 1;
    display: flex;
    flex-direction: column;
    gap: 2px;
  }
  .arb-text strong {
    font-size: 15px;
    color: #1e3a5f;
    font-weight: 600;
  }
  .arb-text span {
    font-size: 13px;
    color: #4b6a8a;
  }
  .btn-request-access {
    flex-shrink: 0;
    padding: 10px 24px;
    background: #2563eb;
    color: #fff;
    border: none;
    border-radius: 8px;
    font-size: 14px;
    font-weight: 600;
    cursor: pointer;
    transition: all 0.15s;
    text-decoration: none;
    display: inline-block;
    white-space: nowrap;
  }
  .btn-request-access:hover { background: #1d4ed8; transform: translateY(-1px); box-shadow: 0 4px 12px rgba(37, 99, 235, 0.3); }
  .btn-request-access:disabled { background: #94a3b8; cursor: not-allowed; transform: none; box-shadow: none; }

  @media (max-width: 768px) {
    .arb-inner {
      flex-direction: column;
      text-align: center;
      padding: 20px 16px;
      gap: 12px;
    }
    .arb-text { align-items: center; }
    .btn-request-access { width: 100%; text-align: center; }
  }

  @media (max-width: 768px) {
    .products-grid { grid-template-columns: 1fr; }
    .cat-toc { gap: 4px 10px; }
    .p-card .p-name {
      font-size: 15px;
      white-space: normal;
      line-height: 1.3;
    }
    .p-features {
      font-size: 12px;
    }
    .p-detail-modal {
      padding: 24px 20px;
    }
    .p-detail-modal-list {
      font-size: 14px;
    }
  }
</style>

<script is:inline>
  // TOC smooth scroll
  document.querySelectorAll('.cat-toc-link').forEach(link => {
    link.addEventListener('click', (ev) => {
      ev.preventDefault();
      const target = document.getElementById(link.getAttribute('href')?.replace('#', '') || '');
      if (target) target.scrollIntoView({ behavior: 'smooth' });
    });
  });

  // 설명 보기 요청 버튼 (catalog 페이지 전용)
  const reqBtn = document.getElementById('requestAccessBtnTop');
  if (reqBtn) {
    reqBtn.addEventListener('click', async () => {
      reqBtn.setAttribute('disabled', '');
      reqBtn.textContent = '요청 중...';
      try {
        const res = await fetch('/api/access-request', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ page: 'catalog' }),
        });
        const data = await res.json();
        if (data.ok) {
          reqBtn.textContent = '요청 완료 — 관리자 승인 대기 중';
        } else {
          reqBtn.textContent = data.error || '요청 실패';
          setTimeout(() => { reqBtn.removeAttribute('disabled'); reqBtn.textContent = '설명 보기 요청'; }, 3000);
        }
      } catch {
        reqBtn.textContent = '서버 연결 실패';
        setTimeout(() => { reqBtn.removeAttribute('disabled'); reqBtn.textContent = '설명 보기 요청'; }, 3000);
      }
    });
  }

  // 설명칸 클릭 시 확대 모달
  const overlay = document.getElementById('detailOverlay');
  const modalTitle = document.getElementById('detailModalTitle');
  const modalList = document.getElementById('detailModalList');
  const modalClose = document.getElementById('detailModalClose');

  function openDetailModal(productName, items) {
    if (!overlay || !modalTitle || !modalList) return;
    modalTitle.textContent = productName;
    modalList.innerHTML = items.map(item => `<li>${item}</li>`).join('');
    overlay.classList.add('active');
    document.body.style.overflow = 'hidden';
  }

  function closeDetailModal() {
    if (!overlay) return;
    overlay.classList.remove('active');
    document.body.style.overflow = '';
  }

  // p-features (ul) 클릭 시 모달 열기 — 관리자는 인라인 편집 우선
  if (!document.getElementById('adminBar')) {
    document.querySelectorAll('.p-features').forEach(function(ul) {
      ul.addEventListener('click', function(ev) {
        ev.preventDefault();
        ev.stopPropagation();
        var card = ul.closest('.p-card');
        if (!card) return;
        var nameEl = card.querySelector('.p-name');
        var productName = nameEl ? nameEl.textContent.trim() : 'Product Details';
        var features = Array.from(ul.querySelectorAll('li')).map(function(li) { return li.textContent || ''; });
        openDetailModal(productName, features);
      });
    });
  }

  // 모달 닫기
  modalClose?.addEventListener('click', closeDetailModal);
  overlay?.addEventListener('click', (ev) => {
    if (ev.target === overlay) closeDetailModal();
  });
  document.addEventListener('keydown', (ev) => {
    if (ev.key === 'Escape') closeDetailModal();
  });
</script>
